      <h3 class="text-white font-bold mb-4 uppercase tracking-widest text-xs">
        Community
      </h3>
      <div class="flex space-x-4">
        <a
          href="#"
          class="p-2 bg-secondary/10 rounded-full hover:bg-accent hover:text-primary transition-all"
        >
          <Instagram size={20} />
        </a>
        <a
          href="#"
          class="p-2 bg-secondary/10 rounded-full hover:bg-accent hover:text-primary transition-all"
        >
          <Twitter size={20} />
        </a>
        <a
          href="#"
          class="p-2 bg-secondary/10 rounded-full hover:bg-accent hover:text-primary transition-all"
