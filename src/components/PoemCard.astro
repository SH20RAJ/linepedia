---
import { Copy, Heart } from 'lucide-astro';

interface Props {
  id: string;
  slug: string;
  content: string;
  writer: string;
  writerName: string;
}

const { id, slug, content, writer, writerName } = Astro.props;
---

<div class="bg-white border border-indigo-50 rounded-2xl p-6 flex flex-col h-full card-shadow card-hover group" data-poem-card data-slug={slug}>
  <div class="flex-grow">
    <blockquote class="italic text-primary/80 leading-relaxed mb-6">
      <p class="whitespace-pre-line text-lg font-serif poem-text">
        "{content}"
      </p>
    </blockquote>
  </div>

  <div class="flex items-center justify-between border-t border-indigo-50 pt-4">
    <a href={`/${writer}`} class="flex items-center space-x-2 group/writer">
      <div class="w-8 h-8 rounded-full bg-indigo-50 flex items-center justify-center overflow-hidden">
        <img src={`https://api.dicebear.com/7.x/avataaars/svg?seed=${writer}`} alt={writerName} loading="lazy" />
      </div>
      <span class="text-sm font-medium text-primary/60 group-hover/writer:text-primary transition-colors">{writerName}</span>
    </a>

    <div class="flex items-center space-x-1">
      <button class="pin-card-btn p-2 text-primary/30 hover:text-[#E60023] transition-colors" title="Pin to Pinterest">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12.289 2C6.617 2 2 6.617 2 12.289c0 4.305 2.605 7.991 6.385 9.556-.089-.81-.131-1.341-.131-1.341s-.581-2.476-.581-2.476-.149-.595.044-.847c.18-.235.617-.308.617-.308s1.603.208 2.613 1.055c.951.802 2.304 1.24 3.731 1.24 4.148 0 7.857-3.14 7.857-8.583 0-5.321-3.692-8.471-8.525-8.471-5.636 0-9.283 3.491-9.283 8.356 0 2.059.569 3.655 1.706 4.704.141.13.296.223.364.076.069-.149.231-.914.3-.1.1.2.062 1.18-.33.324-1.01-1.282-1.369-2.914-1.369-4.704 0-3.321 2.502-6.526 7.154-6.526 3.869 0 6.617 2.766 6.617 6.195 0 4.305-2.152 7.324-5.333 7.324-1.077 0-2.091-.56-2.438-1.222l-.666 2.541c-.241.939-.893 2.115-1.332 2.827 1.026.31 2.119.469 3.255.469 5.672 0 10.289-4.617 10.289-10.289S17.961 2 12.289 2z"/></svg>
      </button>
      <button class="copy-card-btn p-2 text-primary/30 hover:text-accent transition-colors" title="Copy">
        <Copy size={16} />
      </button>
      <a href={`/line/${slug}`} class="ml-4 text-xs font-bold uppercase tracking-widest text-primary/40 hover:text-primary transition-colors">
        Read More
      </a>
    </div>
  </div>
</div>

<script>
  // Copy buttons on cards
  document.querySelectorAll('[data-poem-card]').forEach(card => {
    const copyBtn = card.querySelector('.copy-card-btn');
    const likeBtn = card.querySelector('.like-card-btn');
    const poemText = card.querySelector('.poem-text');

    copyBtn?.addEventListener('click', () => {
      const text = poemText?.textContent?.replace(/^"|"$/g, '').trim() || '';
      navigator.clipboard.writeText(text).then(() => {
        copyBtn.classList.remove('text-primary/30');
        copyBtn.classList.add('text-accent');
        setTimeout(() => {
          copyBtn.classList.add('text-primary/30');
          copyBtn.classList.remove('text-accent');
        }, 1500);
      });
    });

    likeBtn?.addEventListener('click', () => {
      const htmlLikeBtn = likeBtn as HTMLElement;
      const svg = htmlLikeBtn.querySelector('svg');
      const isLiked = htmlLikeBtn.dataset.liked === 'true';
      htmlLikeBtn.dataset.liked = isLiked ? 'false' : 'true';
      htmlLikeBtn.classList.toggle('text-red-500', !isLiked);
      htmlLikeBtn.classList.toggle('text-primary/30', isLiked);
      if (svg) svg.style.fill = isLiked ? 'none' : 'currentColor';
    });

    const pinBtn = card.querySelector('.pin-card-btn');
    pinBtn?.addEventListener('click', () => {
      const text = poemText?.textContent?.replace(/^"|"$/g, '').trim() || '';
      const url = `${window.location.origin}/line/${card.getAttribute('data-slug') || ''}`;
      const imageUrl = `${window.location.origin}/posters/${card.getAttribute('data-slug') || ''}.png`;
      const pinUrl = `https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(url)}&media=${encodeURIComponent(imageUrl)}&description=${encodeURIComponent(text.slice(0, 200))}`;
      window.open(pinUrl, '_blank');
    });
  });
</script>
