---
import { Share2, Copy, Heart } from 'lucide-astro';

interface Props {
  id: string;
  slug: string;
  content: string;
  writer: string;
  writerName: string;
}

const { id, slug, content, writer, writerName } = Astro.props;
---

<div class="bg-white border border-indigo-50 rounded-2xl p-6 flex flex-col h-full card-shadow card-hover group">
  <div class="flex-grow">
    <blockquote class="italic text-primary/80 leading-relaxed mb-6">
      <p class="whitespace-pre-line text-lg font-serif">
        "{content}"
      </p>
    </blockquote>
  </div>

  <div class="flex items-center justify-between border-t border-indigo-50 pt-4">
    <a href={`/writer/${writer}`} class="flex items-center space-x-2 group/writer">
      <div class="w-8 h-8 rounded-full bg-indigo-50 flex items-center justify-center overflow-hidden">
        <img src={`https://api.dicebear.com/7.x/avataaars/svg?seed=${writer}`} alt={writerName} />
      </div>
      <span class="text-sm font-medium text-primary/60 group-hover/writer:text-primary transition-colors">{writerName}</span>
    </a>

    <div class="flex items-center space-x-1">
      <button class="p-2 text-primary/30 hover:text-accent transition-colors" title="Copy">
        <Copy size={16} />
      </button>
      <button class="p-2 text-primary/30 hover:text-red-400 transition-colors" title="Like">
        <Heart size={16} />
      </button>
      <a href={`/line/${slug}`} class="ml-4 text-xs font-bold uppercase tracking-widest text-primary/40 hover:text-primary transition-colors">
        Read More
      </a>
    </div>
  </div>
</div>
