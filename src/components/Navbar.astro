---
import { Search, Menu, X, Home, Compass, PenTool, LayoutGrid, Layers, Heart } from 'lucide-astro';

const navItems = [
  { name: 'Explore', href: '/explore/', icon: Compass },
  { name: 'Blog', href: '/blog/', icon: Search },
  { name: 'Writers', href: '/writers/', icon: PenTool },
  { name: 'Archive', href: '/ap/', icon: Layers },
  { name: 'Likes', href: '/likes/', icon: Heart },
];

const languages = [
  { code: 'en', name: 'English' },
  { code: 'es', name: 'Español' },
  { code: 'hi', name: 'हिन्दी' },
  { code: 'fr', name: 'Français' },
  { code: 'de', name: 'Deutsch' },
  { code: 'ar', name: 'العربية' },
  { code: 'zh', name: '中文' },
  { code: 'ja', name: '日本語' },
  { code: 'ru', name: 'Русский' },
  { code: 'pt', name: 'Português' },
  { code: 'it', name: 'Italiano' }
];
---

<header class="sticky top-0 z-50 bg-cream/80 backdrop-blur-md border-b border-indigo-100">
  <div class="container mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center space-x-2">
      <span class="text-2xl font-serif font-black text-primary tracking-tight">Linespedia</span>
    </a>

    <nav class="hidden md:flex items-center space-x-8">
      {navItems.map(item => (
        <a href={item.href} class="text-sm font-bold text-primary/60 hover:text-accent transition-all uppercase tracking-widest">
          {item.name}
        </a>
      ))}
    </nav>

    <div class="flex items-center space-x-6">
      <div class="relative group h-full flex items-center">
        <button class="flex items-center space-x-1 text-sm font-bold uppercase tracking-widest text-primary/60 hover:text-accent transition-all py-2 cursor-pointer">
          <Compass size={16} />
          <span>Language</span>
        </button>
        <div class="absolute top-full right-0 mt-1 w-48 bg-white/95 backdrop-blur-xl border border-indigo-100 rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 p-2 grid grid-cols-1 gap-1">
          {languages.map(lang => (
            <button 
              class="lang-select-btn px-4 py-2 text-left text-xs font-bold text-primary/70 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all"
              data-lang={lang.code}
            >
              {lang.name}
            </button>
          ))}
        </div>
      </div>
      
      <a href="/submit/" class="hidden md:block px-6 py-2.5 bg-primary text-white text-xs font-black uppercase tracking-widest rounded-full hover:bg-primary/90 hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20">
        Submit Line
      </a>
    </div>

    <button class="md:hidden p-2 text-primary" id="mobile-menu-btn">
      <Menu size={24} />
    </button>
  </div>
</header>

<!-- Mobile Bottom Navigation -->
<nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-indigo-50 px-6 py-3 flex items-center justify-between shadow-[0_-4px_20px_rgba(0,0,0,0.05)]">
  <a href="/" class="flex flex-col items-center space-y-1 text-primary">
    <Home size={20} />
    <span class="text-[10px] font-medium uppercase tracking-wider">Home</span>
  </a>
  {navItems.map(item => (
    <a href={item.href} class="flex flex-col items-center space-y-1 text-primary/60">
      <item.icon size={20} />
      <span class="text-[10px] font-medium uppercase tracking-wider">{item.name}</span>
    </a>
  ))}
</nav>

<style>
  /* Add padding to body to account for fixed bottom nav on mobile */
  @media (max-width: 768px) {
    :global(body) {
      padding-bottom: 72px;
    }
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  menuBtn?.addEventListener('click', () => {
    // Reveal a simple language picker on mobile
    const langPicker = document.getElementById('mobile-lang-picker');
    langPicker?.classList.toggle('hidden');
  });

  // Language Selection Logic
  document.querySelectorAll('.lang-select-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = (btn as HTMLElement).dataset.lang;
      const url = new URL(window.location.href);
      if (lang === 'en') {
        url.searchParams.delete('lang');
      } else {
        url.searchParams.set('lang', lang!);
      }
      window.location.href = url.toString();
    });
  });
</script>
