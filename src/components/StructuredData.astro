---
interface Props {
  type: "line" | "writer" | "category" | "collection";
  title: string;
  description: string;
  url: string;
  language?: string;
  authorName?: string;
  datePublished?: string;
  breadcrumbs?: { name: string; url: string }[];
  faqs?: { q: string; a: string }[];
}

const {
  type,
  title,
  description,
  url,
  language,
  authorName,
  datePublished,
  breadcrumbs = [],
  faqs = [],
} = Astro.props;
const siteUrl = Astro.site?.toString() || "https://linespedia.com";
const inferredLanguage = String(Astro.url.searchParams.get("lang") || "en").toLowerCase();
const schemaLanguage = language || inferredLanguage;

// WebSite schema with SearchAction (sitewide)
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}#website`,
  name: "Linespedia",
  url: siteUrl,
  inLanguage: schemaLanguage,
  potentialAction: {
    "@type": "SearchAction",
    target: `${siteUrl}/explore?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};

// Breadcrumb schema
const breadcrumbSchema =
  breadcrumbs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbs.map((crumb, index) => ({
          "@type": "ListItem",
          position: index + 1,
          name: crumb.name,
          item: crumb.url.startsWith("http")
            ? crumb.url
            : `${siteUrl}${crumb.url}`,
        })),
      }
    : null;

// CreativeWork / Article schema
const contentSchema =
  type === "line"
    ? {
        "@context": "https://schema.org",
        "@type": "Poem",
        "@id": url.startsWith("http") ? `${url}#poem` : `${siteUrl}${url}#poem`,
        name: title,
        description: description,
        inLanguage: schemaLanguage,
        author: {
          "@type": "Person",
          name: authorName || "Unknown",
        },
        genre: "Poetry",
        url: url.startsWith("http") ? url : `${siteUrl}${url}`,
        datePublished: datePublished || new Date().toISOString(),
        publisher: {
          "@type": "Organization",
          name: "Linespedia",
          logo: {
            "@type": "ImageObject",
            url: `${siteUrl}/logo.png`,
          },
        },
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": url.startsWith("http") ? url : `${siteUrl}${url}`,
        },
      }
    : type === "writer"
      ? {
          "@context": "https://schema.org",
          "@type": "Person",
          "@id": url.startsWith("http") ? `${url}#person` : `${siteUrl}${url}#person`,
          name: title,
          description: description,
          inLanguage: schemaLanguage,
          url: url.startsWith("http") ? url : `${siteUrl}${url}`,
        }
      : {
          "@context": "https://schema.org",
          "@type": "CollectionPage",
          "@id": url.startsWith("http") ? `${url}#collection` : `${siteUrl}${url}#collection`,
          name: title,
          description: description,
          inLanguage: schemaLanguage,
          url: url.startsWith("http") ? url : `${siteUrl}${url}`,
          publisher: {
            "@type": "Organization",
            name: "Linespedia",
            url: siteUrl,
          },
        };

// FAQ Schema
const faqSchema =
  faqs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        inLanguage: schemaLanguage,
        mainEntity: faqs.map((faq) => ({
          "@type": "Question",
          name: faq.q,
          acceptedAnswer: {
            "@type": "Answer",
            text: faq.a,
          },
        })),
      }
    : null;
---

<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
{
  breadcrumbSchema && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  )
}
{
  faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )
}
<script type="application/ld+json" set:html={JSON.stringify(contentSchema)} />
