---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Send, CheckCircle, AlertCircle, List } from 'lucide-astro';

const title = "IndexNow Submission Portal | Linespedia";
const description = "Batch submit your URLs to IndexNow for faster search engine discovery.";
---

<Layout title={title} description={description}>
    <Navbar />
    
    <main class="min-h-screen pt-32 pb-20 bg-slate-50">
        <div class="container mx-auto px-4 max-w-3xl">
            <header class="text-center mb-12">
                <h1 class="text-4xl font-serif font-black text-slate-900 mb-4">IndexNow Portal</h1>
                <p class="text-slate-600">Instantly notify search engines (Bing, Yandex, etc.) about new or updated pages.</p>
            </header>

            <div class="bg-white rounded-[2rem] shadow-xl border border-slate-100 p-8 md:p-12">
                <div class="mb-4 flex gap-4">
                    <button 
                        id="fetch-sitemap-btn" 
                        class="flex-1 flex items-center justify-center gap-2 py-3 bg-slate-100 text-slate-600 rounded-xl font-bold hover:bg-slate-200 transition-all text-sm"
                    >
                        <List size={16} />
                        Fetch from Sitemap
                    </button>
                    <button 
                        id="submit-all-btn" 
                        class="flex-1 flex items-center justify-center gap-2 py-3 bg-indigo-50 text-indigo-600 rounded-xl font-bold hover:bg-indigo-100 transition-all text-sm"
                    >
                        <Send size={16} />
                        Submit All (Sitemaps)
                    </button>
                </div>

                <div class="mb-8">
                    <label for="urls" class="block text-sm font-bold text-slate-700 uppercase tracking-widest mb-3 flex items-center gap-2">
                        <List size={16} />
                        URL List (One per line)
                    </label>
                    <textarea 
                        id="urls" 
                        rows="10" 
                        class="w-full p-6 bg-slate-50 border-2 border-slate-100 rounded-2xl font-mono text-sm focus:border-indigo-500 focus:outline-none transition-all"
                        placeholder="https://linespedia.com/p/your-slug/&#10;https://linespedia.com/p/another-one/"
                    ></textarea>
                </div>

                <div class="flex items-center justify-between gap-6">
                    <div id="status-display" class="hidden flex items-center gap-3 py-3 px-5 rounded-full text-sm font-bold">
                        <!-- Status injected here -->
                    </div>
                    
                    <button 
                        id="submit-btn" 
                        class="ml-auto flex items-center gap-3 px-10 py-5 bg-indigo-600 text-white rounded-full font-bold hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-100 active:scale-95 disabled:opacity-50"
                    >
                        <Send size={20} />
                        <span>Submit Batch</span>
                    </button>
                </div>

                <div class="mt-12 pt-8 border-t border-slate-50">
                    <h3 class="text-xs font-black text-slate-300 uppercase tracking-[0.2em] mb-4">Technical Details</h3>
                    <div class="grid grid-cols-2 gap-4 text-[10px] font-bold text-slate-400">
                        <div class="bg-slate-50 p-4 rounded-xl">
                            <span class="block text-slate-300 mb-1">Host</span>
                            linespedia.com
                        </div>
                        <div class="bg-slate-50 p-4 rounded-xl">
                            <span class="block text-slate-300 mb-1">Key Location</span>
                            /2f3a29d127b84110a911375a73d97702.txt
                        </div>
                    </div>
                    <p class="mt-4 text-[11px] text-slate-500 leading-relaxed">
                        Requests are submitted through a server-side proxy to avoid browser CORS issues with the public IndexNow endpoint.
                    </p>
                </div>
            </div>
        </div>
    </main>
    
    <Footer />
</Layout>

<script is:inline>
    const submitBtn = document.getElementById('submit-btn');
    const submitAllBtn = document.getElementById('submit-all-btn');
    const fetchBtn = document.getElementById('fetch-sitemap-btn');
    const urlsArea = document.getElementById('urls');
    const statusDisplay = document.getElementById('status-display');
    
    const ROOT_SITEMAP = '/sitemap.xml';
    const MAX_URLS = 50000;
    const MAX_SITEMAPS = 120;
    const PROXY_ENDPOINT = '/api/indexnow-proxy/';

    const fetchLabel = fetchBtn?.textContent?.trim() || 'Fetch from Sitemap';

    async function fetchSitemaps() {
        if (!fetchBtn || !urlsArea) return;

        fetchBtn.disabled = true;
        fetchBtn.textContent = 'Fetching...';
        
        try {
            const sitemapQueue = [new URL(ROOT_SITEMAP, window.location.origin).toString()];
            const visitedSitemaps = new Set();
            const discoveredUrls = [];
            const seenUrls = new Set();

            while (sitemapQueue.length > 0 && discoveredUrls.length < MAX_URLS && visitedSitemaps.size < MAX_SITEMAPS) {
                const sitemapUrl = sitemapQueue.shift();
                if (!sitemapUrl || visitedSitemaps.has(sitemapUrl)) continue;

                visitedSitemaps.add(sitemapUrl);
                const res = await fetch(sitemapUrl, { cache: 'no-store' });
                if (!res.ok) {
                    throw new Error(`Failed to fetch ${sitemapUrl}`);
                }

                const text = await res.text();
                const parser = new DOMParser();
                const xmlDoc = parser.parseFromString(text, 'text/xml');
                if (xmlDoc.querySelector('parsererror')) {
                    throw new Error(`Invalid XML at ${sitemapUrl}`);
                }

                const locs = Array.from(xmlDoc.getElementsByTagName('loc'))
                    .map((node) => node.textContent?.trim())
                    .filter(Boolean);

                const isSitemapIndex = xmlDoc.getElementsByTagName('sitemapindex').length > 0;
                if (isSitemapIndex) {
                    locs.forEach((loc) => {
                        const absolute = new URL(loc, window.location.origin).toString();
                        if (!visitedSitemaps.has(absolute)) sitemapQueue.push(absolute);
                    });
                    continue;
                }

                for (const loc of locs) {
                    if (seenUrls.has(loc)) continue;
                    seenUrls.add(loc);
                    discoveredUrls.push(loc);
                    if (discoveredUrls.length >= MAX_URLS) break;
                }
            }

            urlsArea.value = discoveredUrls.join('\n');
            const capped = discoveredUrls.length >= MAX_URLS ? ` (capped at ${MAX_URLS.toLocaleString()})` : '';
            showStatus(`Fetched ${discoveredUrls.length.toLocaleString()} URLs from ${visitedSitemaps.size} sitemap files${capped}`, 'indigo');
        } catch (e) {
            showStatus('Error fetching sitemaps', 'rose');
        } finally {
            fetchBtn.disabled = false;
            fetchBtn.textContent = fetchLabel;
        }
    }

    function showStatus(msg, color) {
        if (!statusDisplay) return;
        statusDisplay.className = `flex items-center gap-3 py-3 px-5 rounded-full text-sm font-bold bg-${color}-50 text-${color}-600`;
        statusDisplay.innerHTML = `<span>${msg}</span>`;
        statusDisplay.classList.remove('hidden');
    }

    async function submitIndexNow(urlsToSubmit) {
        if (!submitBtn || !urlsArea) return;

        const val = urlsToSubmit || urlsArea?.value.trim() || '';
        if (!val) return;
        
        const urls = Array.isArray(val) ? val : val.split('\n').map(u => u.trim()).filter(Boolean);
        if (urls.length === 0) return;

        submitBtn.disabled = true;
        const originalText = submitBtn.querySelector('span').textContent;
        submitBtn.querySelector('span').textContent = 'Submitting...';
        
        showStatus(`Processing ${urls.length} URLs...`, 'indigo');

        // Batch by 10,000 (IndexNow limit)
        const batchSize = 10000;
        for (let i = 0; i < urls.length; i += batchSize) {
            const batch = urls.slice(i, i + batchSize);
            try {
                const res = await fetch(PROXY_ENDPOINT, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        urlList: batch
                    })
                });

                if (!res.ok) {
                    const payload = await res.json().catch(() => ({}));
                    throw new Error(payload?.error || 'Submission failed');
                }
            } catch (e) {
                const message = e?.message ? `Submission Error: ${e.message}` : 'Submission Error';
                showStatus(message, 'rose');
                submitBtn.disabled = false;
                submitBtn.querySelector('span').textContent = originalText;
                return;
            }
        }

        showStatus('Successfully Submitted!', 'emerald');
        submitBtn.disabled = false;
        submitBtn.querySelector('span').textContent = originalText;
    }

    async function submitAll() {
        await fetchSitemaps();
        const urls = urlsArea.value.split('\n').filter(Boolean);
        if (urls.length > 0) {
            await submitIndexNow(urls);
        }
    }

    fetchBtn?.addEventListener('click', fetchSitemaps);
    submitBtn?.addEventListener('click', () => submitIndexNow());
    submitAllBtn?.addEventListener('click', submitAll);
</script>
