---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import PoemCard from '../components/PoemCard.astro';
import StructuredData from '../components/StructuredData.astro';
import { Quote } from 'lucide-astro';

import poemsData from '../content/poems.json';
import writersData from '../content/writers.json';
import categoriesData from '../content/categories.json';
import collectionsData from '../content/collections.json';

const featuredPoems = poemsData.slice(0, 9);
const trendingCategories = categoriesData.slice(0, 8);
const featuredWriters = writersData.slice(0, 12);
const featuredCollections = collectionsData.slice(0, 4);

// SEO: Poem of the Day (random but stable for the day)
const today = new Date().toDateString();
const seed = today.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0);
const poemOfTheDay = poemsData[seed % poemsData.length];

// Trending Lines (last 6)
const trendingLines = poemsData.slice(-6).reverse();
---

<Layout title="Best Shayari, Poems & Quotes Collection" description="Linespedia — The largest collection of curated poetry, shayari, and quotes. Browse by mood, writer, or theme. Copy paste ready for Instagram, WhatsApp & more.">
	<StructuredData
		type="category"
		title="Linespedia — Best Shayari, Poems & Quotes"
		description="The largest collection of curated poetry, shayari, and quotes."
		url="/"
		breadcrumbs={[]}
	/>
	<Navbar />

	<main>
		<Hero />

		{/* Poem of the Day — Fresh Content Signal */}
		<section class="container mx-auto px-4 -mt-12 relative z-20">
			<div class="bg-primary text-white p-8 md:p-12 rounded-[2.5rem] shadow-2xl overflow-hidden relative group">
				<div class="absolute top-0 right-0 p-8 opacity-10 group-hover:scale-110 transition-transform"><Quote size={120} /></div>
				<div class="max-w-3xl">
					<span class="inline-block px-4 py-1 bg-white/10 rounded-full text-xs font-bold uppercase tracking-widest mb-6 border border-white/10">Poem of the Day</span>
					<blockquote class="text-2xl md:text-4xl font-serif italic mb-8 leading-relaxed">
						"{poemOfTheDay.content.slice(0, 150)}..."
					</blockquote>
					<div class="flex items-center justify-between">
						<a href={`/line/${poemOfTheDay.slug}/`} class="flex items-center space-x-3 group/author">
							<div class="w-10 h-10 rounded-full bg-white/20 border border-white/20 overflow-hidden">
								<img src={`https://api.dicebear.com/7.x/avataaars/svg?seed=${poemOfTheDay.writer}`} alt={poemOfTheDay.writer} />
							</div>
							<span class="font-bold border-b border-transparent group-hover/author:border-white transition-all underline-offset-4">{writersData.find(w => w.slug === poemOfTheDay.writer)?.name || poemOfTheDay.writer}</span>
						</a>
						<a href={`/line/${poemOfTheDay.slug}/`} class="px-6 py-3 bg-white text-primary rounded-full font-bold text-sm hover:bg-accent hover:text-white transition-all shadow-lg">Read Full Poem &rarr;</a>
					</div>
				</div>
			</div>
		</section>

		{/* Trending Categories */}
		<section class="container mx-auto px-4 py-16">
			<div class="flex items-end justify-between mb-8">
				<div>
					<h2 class="text-3xl font-serif font-black text-primary">Trending Categories</h2>
					<p class="text-primary/50 mt-1">Explore curated themes and moods</p>
				</div>
				<a href="/categories/" class="text-accent font-bold text-sm uppercase tracking-widest hover:underline">View All</a>
			</div>
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
				{trendingCategories.map(cat => (
					<a href={`/${cat.slug}/`} class="group p-6 bg-white border border-indigo-50 rounded-2xl shadow-sm hover:shadow-xl transition-all card-hover">
						<h3 class="text-xl font-serif font-bold text-primary group-hover:text-accent transition-colors mb-2">{cat.name}</h3>
						<p class="text-xs text-primary/40 line-clamp-2">{cat.description}</p>
					</a>
				))}
			</div>
		</section>

		{/* Featured Writers */}
		<section class="bg-indigo-50/50 py-16">
			<div class="container mx-auto px-4">
				<div class="flex items-end justify-between mb-12">
					<div>
						<h2 class="text-3xl font-serif font-black text-primary">Featured Poets</h2>
						<p class="text-primary/50 mt-1">The masters of the spoken word</p>
					</div>
					<a href="/writers/" class="text-accent font-bold text-sm uppercase tracking-widest hover:underline">See All</a>
				</div>
				<div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-8">
					{featuredWriters.map(writer => (
						<a href={`/${writer.slug}/`} class="flex flex-col items-center group">
							<img src={writer.photo} alt={writer.name} class="w-20 h-20 md:w-28 md:h-28 rounded-full object-cover shadow-lg border-4 border-white card-hover mb-4" loading="lazy" />
							<h3 class="text-sm md:text-base font-bold text-primary group-hover:text-accent transition-colors text-center">{writer.name}</h3>
							<span class="text-[10px] text-primary/40 font-medium uppercase tracking-widest">{writer.stats.poems} Poems</span>
						</a>
					))}
				</div>
			</div>
		</section>

		{/* Popular Collections */}
		<section class="container mx-auto px-4 py-16">
			<div class="flex items-end justify-between mb-12">
				<div>
					<h2 class="text-3xl font-serif font-black text-primary">Popular Collections</h2>
					<p class="text-primary/50 mt-1">Curated for every mood and occasion</p>
				</div>
				<a href="/collections/" class="text-accent font-bold text-sm uppercase tracking-widest hover:underline">View All</a>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				{featuredCollections.map(col => (
					<a href={`/${col.slug}/`} class="group p-8 bg-white border border-indigo-50 rounded-[2rem] shadow-sm hover:shadow-xl transition-all card-hover">
						<h3 class="text-2xl font-serif font-bold text-primary group-hover:text-accent transition-colors mb-3">{col.name}</h3>
						<p class="text-primary/50 text-sm line-clamp-2 mb-4">{col.description}</p>
						<span class="text-xs font-bold uppercase tracking-widest text-accent">Browse Collection &rarr;</span>
					</a>
				))}
			</div>
		</section>

		{/* Latest Lines Grid */}
		<section class="container mx-auto px-4 py-16">
			<div class="flex items-end justify-between mb-12">
				<div>
					<h2 class="text-3xl font-serif font-black text-primary">Latest Lines</h2>
					<p class="text-primary/50 mt-1">Freshly curated poetry and shayari</p>
				</div>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{featuredPoems.map(poem => (
					<PoemCard
						id={poem.id}
						slug={poem.slug}
						content={poem.content.slice(0, 200)}
						writer={poem.writer}
						writerName={writersData.find(w => w.slug === poem.writer)?.name || poem.writer}
					/>
				))}
			</div>
			<div class="mt-16 flex justify-center">
				<a href="/explore/" class="px-12 py-4 bg-white border border-indigo-100 rounded-full text-primary font-bold shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all">
					Explore All Lines &rarr;
				</a>
			</div>
		</section>

		{/* Trending Now Sidebar/Section — Internal Linking Boost */}
		<section class="bg-white py-16 border-y border-indigo-50">
			<div class="container mx-auto px-4">
				<div class="flex items-center space-x-2 mb-10">
					<div class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></div>
					<h2 class="text-xl font-bold uppercase tracking-widest text-primary/40">Trending Now</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{trendingLines.map(line => (
						<a href={`/line/${line.slug}/`} class="flex items-start space-x-4 p-4 rounded-2xl hover:bg-indigo-50 transition-all border border-transparent hover:border-indigo-100 group">
							<div class="w-12 h-12 rounded-xl bg-primary/5 flex items-center justify-center grow-0 shrink-0 text-primary group-hover:bg-primary group-hover:text-white transition-all">
								<Quote size={20} />
							</div>
							<div>
								<p class="text-primary font-medium line-clamp-2 mb-1">"{line.content.slice(0, 100)}..."</p>
								<span class="text-xs text-primary/40 font-bold uppercase tracking-wider">{writersData.find(w => w.slug === line.writer)?.name || line.writer}</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		{/* SEO Content Block — ensures homepage is not thin */}
		<section class="container mx-auto px-4 py-16 max-w-4xl">
			<div class="prose prose-indigo max-w-none">
				<h2 class="text-3xl font-serif font-black text-primary">About Linespedia</h2>
				<p class="text-primary/70 leading-relaxed text-lg">
					Linespedia is the internet's most comprehensive collection of poetry, shayari, quotes, and poetic lines. We curate content from legendary poets like Shakespeare, Emily Dickinson, Edgar Allan Poe, and many more. Whether you're looking for sad shayari to express your grief, love poetry to share with your partner, or deep lines for your Instagram captions — Linespedia has it all.
				</p>
				<p class="text-primary/70 leading-relaxed">
					Our collection spans multiple languages and moods. Every line is accompanied by its meaning and context, making it perfect for students, poetry enthusiasts, and social media users. Browse by writer, category, mood, or use our curated collections designed for specific platforms like Instagram, WhatsApp, and Facebook.
				</p>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
