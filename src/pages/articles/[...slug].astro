---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { Calendar, Tag, Share2, Copy, Bookmark, Sparkles, MessageSquare, Twitter, Clock } from 'lucide-astro';
import { marked } from 'marked';

// Enable SSR for this route
export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

interface ArticleMeta {
  slug: string;
  title: string;
  date: string;
  image: string;
  categories: string[];
  url: string;
  excerpt: string;
}

// Fetch Metadata to get Title/Image
const metaRes = await fetch('https://cdn.jsdelivr.net/gh/BluredCodes/linespedia-data@main/blogs/dpquotes-meta.json');
const meta = await metaRes.json() as ArticleMeta[];
const articleData = meta.find((a: ArticleMeta) => a.slug === slug);

if (!articleData) {
  return Astro.redirect('/404');
}

// Fetch Markdown Content from CDN
const res = await fetch(`https://cdn.jsdelivr.net/gh/BluredCodes/linespedia-data@main/blogs/dpquotes/${slug}.md`);
if (!res.ok) {
    return Astro.redirect('/404');
}
const rawMarkdown = await res.text();

// Parse Markdown, stripping frontmatter
const contentOnly = rawMarkdown.replace(/^---[\s\S]*?---\n*/, '');
const htmlContent = marked.parse(contentOnly);

// SEO Overrides
const title = articleData.title;
const description = `${articleData.title} - Explore curated quotes, deep insights, and life lessons in this comprehensive guide.`;
const ogImage = articleData.image;

// Schema.org Article
const schema = {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": articleData.title,
    "image": [articleData.image],
    "datePublished": articleData.date,
    "author": [{
        "@type": "Organization",
        "name": "Linespedia",
        "url": "https://linespedia.com"
    }]
};
---

<Layout title={title} description={description} image={ogImage}>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <Navbar />

    <main class="min-h-screen bg-[#fdfcf7] pt-32 pb-24">
        <div class="container mx-auto px-4 max-w-6xl">
            {/* Hero Header */}
            <div class="max-w-4xl mx-auto text-center mb-16 space-y-8 animate-in fade-in slide-in-from-bottom-8 duration-700">
                <nav class="flex justify-center items-center space-x-3 text-[10px] font-black uppercase tracking-widest text-primary/30">
                    <a href="/" class="hover:text-indigo-600 transition-colors">Home</a>
                    <span>/</span>
                    <a href="/articles/" class="hover:text-indigo-600 transition-colors">Articles</a>
                    <span>/</span>
                    <span class="text-indigo-600">{articleData.categories?.[0] || 'Life'}</span>
                </nav>

                <h1 class="text-4xl md:text-6xl font-serif font-black text-primary leading-tight">
                    {articleData.title}
                </h1>

                <div class="flex flex-wrap justify-center items-center gap-6 text-[10px] font-black uppercase tracking-widest text-primary/40">
                    <div class="flex items-center space-x-2">
                        <Calendar size={14} class="text-indigo-600" />
                        <span>{new Date(articleData.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                    </div>
                    <div class="flex items-center space-x-2">
                        <Clock size={14} class="text-indigo-600" />
                        <span>5 Min Read</span>
                    </div>
                    <div class="flex items-center space-x-2">
                        <Tag size={14} class="text-indigo-600" />
                        <span>{articleData.categories?.[0] || 'Wisdom'}</span>
                    </div>
                </div>
            </div>

            {/* Main Featured Image */}
            {articleData.image && (
                <div class="relative w-full aspect-21/9 rounded-[3rem] overflow-hidden mb-20 shadow-2xl shadow-primary/10 border border-primary/5">
                    <img src={articleData.image} alt={articleData.title} class="w-full h-full object-cover" />
                    <div class="absolute inset-0 bg-linear-to-t from-black/20 to-transparent"></div>
                </div>
            )}

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
                {/* Left: Content */}
                <article class="lg:col-span-8 space-y-12">
                    {/* Poetic Insight (Puter AI Placeholder) */}
                    <div class="bg-indigo-600 rounded-[3rem] p-8 md:p-12 text-white relative overflow-hidden group shadow-2xl shadow-indigo-600/20">
                        <div class="absolute -top-24 -right-24 w-64 h-64 bg-white/10 rounded-full blur-3xl group-hover:bg-white/20 transition-all duration-700"></div>
                        <div class="relative z-10 space-y-6">
                            <div class="flex items-center space-x-3">
                                <div class="p-3 bg-white/20 backdrop-blur-md rounded-2xl">
                                    <Sparkles size={24} />
                                </div>
                                <span class="font-black uppercase tracking-widest text-xs opacity-80">AI Poetic Insight</span>
                            </div>
                            <h3 class="text-2xl font-serif font-bold leading-snug">
                                "The rhythm of gratitude is the heartbeat of abundance."
                            </h3>
                            <p class="text-indigo-100/80 leading-relaxed font-medium">
                                This article explores the transformative power of perspective. Use these quotes to ground your daily practice and attract the energy you wish to manifest.
                            </p>
                        </div>
                    </div>

                    {/* Article Content */}
                    <div class="prose prose-xl prose-indigo max-w-none 
                        prose-headings:font-serif prose-headings:font-black prose-headings:text-primary 
                        prose-p:text-primary/70 prose-p:leading-relaxed prose-p:font-medium
                        prose-img:rounded-[2rem] prose-img:shadow-xl
                        prose-blockquote:border-l-4 prose-blockquote:border-indigo-600 prose-blockquote:bg-indigo-50 prose-blockquote:p-8 prose-blockquote:rounded-r-[2rem] prose-blockquote:font-serif prose-blockquote:italic
                    " set:html={htmlContent}>
                    </div>

                    {/* Sharing Footer */}
                    <div class="pt-16 border-t border-primary/5 flex flex-col md:flex-row items-center justify-between gap-8">
                        <div class="flex items-center space-x-4">
                            <span class="text-[10px] font-black uppercase tracking-widest text-primary/30">Spread the Wisdom</span>
                            <div class="flex space-x-3">
                                <button class="p-4 bg-white border border-primary/5 rounded-full hover:bg-green-500 hover:text-white transition-all shadow-xl shadow-primary/5 group">
                                    <MessageSquare size={18} />
                                </button>
                                <button class="p-4 bg-white border border-primary/5 rounded-full hover:bg-indigo-400 hover:text-white transition-all shadow-xl shadow-primary/5 group">
                                    <Twitter size={18} />
                                </button>
                                <button class="p-4 bg-white border border-primary/5 rounded-full hover:bg-indigo-600 hover:text-white transition-all shadow-xl shadow-primary/5 group">
                                    <Share2 size={18} />
                                </button>
                            </div>
                        </div>
                        <button class="flex items-center space-x-3 px-8 py-4 bg-primary text-white rounded-full font-bold text-xs uppercase tracking-widest hover:bg-indigo-600 transition-colors shadow-xl shadow-primary/20">
                            <Copy size={16} />
                            <span>Copy Article Link</span>
                        </button>
                    </div>
                </article>

                {/* Right: Sidebar */}
                <aside class="lg:col-span-4 space-y-12">
                    {/* Navigation Widget */}
                    <div class="bg-white border border-primary/5 rounded-[3rem] p-8 shadow-xl shadow-primary/5 sticky top-32">
                        <h4 class="text-xl font-serif font-black text-primary mb-8 flex items-center">
                            <Bookmark size={20} class="mr-3 text-indigo-600" />
                            Guide Navigation
                        </h4>
                        <div class="space-y-6">
                            <a href="#introduction" class="flex items-center group text-primary/50 hover:text-indigo-600 transition-colors">
                                <span class="w-8 h-8 rounded-full bg-indigo-50 flex items-center justify-center text-[10px] font-black text-indigo-600 mr-4 group-hover:bg-indigo-600 group-hover:text-white transition-all">01</span>
                                <span class="font-bold text-sm">Introduction</span>
                            </a>
                            <a href="#quotes" class="flex items-center group text-primary/50 hover:text-indigo-600 transition-colors">
                                <span class="w-8 h-8 rounded-full bg-indigo-50 flex items-center justify-center text-[10px] font-black text-indigo-600 mr-4 group-hover:bg-indigo-600 group-hover:text-white transition-all">02</span>
                                <span class="font-bold text-sm">Curated Quotes</span>
                            </a>
                            <a href="#summary" class="flex items-center group text-primary/50 hover:text-indigo-600 transition-colors">
                                <span class="w-8 h-8 rounded-full bg-indigo-50 flex items-center justify-center text-[10px] font-black text-indigo-600 mr-4 group-hover:bg-indigo-600 group-hover:text-white transition-all">03</span>
                                <span class="font-bold text-sm">Final Summary</span>
                            </a>
                        </div>

                        {/* Newsletter Widget */}
                        <div class="mt-12 pt-12 border-t border-primary/5 space-y-6">
                            <h4 class="text-lg font-serif font-bold text-primary">Join the Sanctuary</h4>
                            <p class="text-xs text-primary/40 leading-relaxed font-medium">
                                Get weekly poetic insights and curation directly in your inbox.
                            </p>
                            <form class="space-y-3">
                                <input type="email" placeholder="email@address.com" class="w-full px-6 py-4 bg-indigo-50 rounded-2xl text-xs focus:outline-none focus:ring-2 focus:ring-indigo-600/20" />
                                <button class="w-full py-4 bg-indigo-600 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-indigo-700 transition-colors shadow-lg shadow-indigo-600/20">
                                    Subscribe Now
                                </button>
                            </form>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
