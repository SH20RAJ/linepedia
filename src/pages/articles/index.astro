---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { Search, Calendar, Tag, ChevronRight, Sparkles } from 'lucide-astro';

// Enable SSR for this route
export const prerender = false;

interface ArticleMeta {
  slug: string;
  title: string;
  date: string;
  image: string;
  categories: string[];
  url: string;
  excerpt: string;
}

// Fetch Metadata from CDN
const metaRes = await fetch('https://cdn.jsdelivr.net/gh/BluredCodes/linespedia-data@main/blogs/dpquotes-meta.json');
const allArticles = await metaRes.json() as ArticleMeta[];

const sortedArticles = allArticles.sort((a, b) => 
    new Date(b.date).getTime() - new Date(a.date).getTime()
);

// Pagination Logic
const ITEMS_PER_PAGE = 12;
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const totalPages = Math.ceil(sortedArticles.length / ITEMS_PER_PAGE);
const currentArticles = sortedArticles.slice((page - 1) * ITEMS_PER_PAGE, page * ITEMS_PER_PAGE);

const siteTitle = "Insightful Articles & Quotes | Linespedia";
const siteDescription = "Explore deep insights, life lessons, and curated quotes from our latest article collection.";
---

<Layout title={siteTitle} description={siteDescription}>
    <Navbar />
    
    <main class="min-h-screen bg-[#fdfcf7] pt-32 pb-24">
        <div class="container mx-auto px-4 max-w-7xl">
            {/* Header Section */}
            <div class="text-center mb-16 space-y-6 animate-in fade-in slide-in-from-bottom-8 duration-700">
                <div class="inline-flex items-center space-x-3 px-4 py-2 bg-indigo-50 rounded-full border border-indigo-100 mb-4">
                    <Sparkles class="text-indigo-600" size={16} />
                    <span class="text-indigo-600 font-bold text-[10px] uppercase tracking-widest text-primary/40">Knowledge Base</span>
                </div>
                <h1 class="text-5xl md:text-7xl font-serif font-black text-primary leading-tight">
                    Poetic <span class="text-indigo-600 italic">Conversations</span>
                </h1>
                <p class="text-xl text-primary/50 max-w-2xl mx-auto leading-relaxed">
                    Dive into our curated library of deep-form articles, quotes, and cultural insights designed to inspire the modern soul.
                </p>

                {/* Search Bar */}
                <div class="mt-12 max-w-2xl mx-auto relative group">
                    <div class="absolute inset-y-0 left-6 flex items-center pointer-events-none text-primary/20 group-focus-within:text-indigo-600 transition-colors">
                        <Search size={22} />
                    </div>
                    <input 
                        type="text" 
                        id="article-search"
                        placeholder="Search articles, keywords, or topics..." 
                        class="w-full pl-16 pr-8 py-6 bg-white border-2 border-primary/5 rounded-[2.5rem] text-lg focus:outline-none focus:border-indigo-600/20 focus:ring-4 focus:ring-indigo-600/5 transition-all shadow-xl shadow-primary/5 placeholder:text-primary/20"
                    />
                </div>
            </div>

            {/* Articles Grid */}
            <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {currentArticles.map((article) => (
                    <a href={`/articles/${article.slug}/`} class="article-card group bg-white border border-primary/5 rounded-[3rem] p-6 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 overflow-hidden relative">
                        <div class="aspect-[16/10] rounded-[2rem] overflow-hidden mb-6 bg-indigo-50 relative">
                            {article.image ? (
                                <img 
                                    src={article.image} 
                                    alt={article.title} 
                                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
                                    loading="lazy"
                                />
                            ) : (
                                <div class="w-full h-full flex items-center justify-center text-indigo-200">
                                    <Tag size={48} strokeWidth={1} />
                                </div>
                            )}
                            <div class="absolute top-4 left-4">
                                <span class="px-4 py-2 bg-white/90 backdrop-blur-md rounded-full text-[10px] font-black uppercase tracking-widest text-indigo-600 shadow-sm">
                                    {article.categories?.[0] || 'Article'}
                                </span>
                            </div>
                        </div>

                        <div class="space-y-4 px-2">
                            <div class="flex items-center space-x-3 text-primary/30 text-[10px] font-black uppercase tracking-widest">
                                <Calendar size={12} />
                                <span>{new Date(article.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                            </div>
                            <h2 class="text-2xl font-serif font-black text-primary group-hover:text-indigo-600 transition-colors leading-tight">
                                {article.title}
                            </h2>
                            <p class="text-primary/40 text-sm line-clamp-2 leading-relaxed font-medium">
                                {article.title} — Discover curated quotes, life lessons, and deep insights from our latest collection.
                            </p>
                            <div class="pt-4 flex items-center text-indigo-600 font-bold text-xs uppercase tracking-widest group/btn">
                                <span>Read Full Article</span>
                                <ChevronRight size={16} class="ml-2 group-hover/btn:translate-x-1 transition-transform" />
                            </div>
                        </div>
                    </a>
                ))}
            </div>

            {/* Pagination */}
            {totalPages > 1 && (
                <div class="mt-20 flex justify-center items-center space-x-4">
                    {page > 1 && (
                        <a href={`/articles/?page=${page - 1}`} class="p-6 bg-white border border-primary/5 rounded-full hover:bg-indigo-600 hover:text-white transition-all shadow-xl shadow-primary/5 group">
                            <ChevronRight class="rotate-180 group-hover:scale-110 transition-transform" size={24} />
                        </a>
                    )}
                    
                    <div class="flex items-center space-x-3">
                        {Array.from({ length: totalPages }).map((_, i) => (
                            <a 
                                href={`/articles/?page=${i + 1}`} 
                                class={`w-12 h-12 flex items-center justify-center rounded-full font-black text-sm transition-all ${page === i + 1 ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-600/20' : 'bg-white border border-primary/5 text-primary/40 hover:bg-indigo-50'}`}
                            >
                                {i + 1}
                            </a>
                        ))}
                    </div>

                    {page < totalPages && (
                        <a href={`/articles/?page=${page + 1}`} class="p-6 bg-white border border-primary/5 rounded-full hover:bg-indigo-600 hover:text-white transition-all shadow-xl shadow-primary/5 group">
                            <ChevronRight class="group-hover:scale-110 transition-transform" size={24} />
                        </a>
                    )}
                </div>
            )}
        </div>
    </main>

    <Footer />
</Layout>

<script>
    // Simple client-side search logic
    const searchInput = document.getElementById('article-search') as HTMLInputElement;
    const cards = document.querySelectorAll('.article-card');

    searchInput?.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase();
        
        cards.forEach(card => {
            const title = card.querySelector('h2')?.textContent?.toLowerCase() || '';
            const category = card.querySelector('.uppercase')?.textContent?.toLowerCase() || '';
            
            if (title.includes(query) || category.includes(query)) {
                (card as HTMLElement).style.display = 'block';
                (card as HTMLElement).classList.add('animate-in', 'fade-in', 'scale-95');
            } else {
                (card as HTMLElement).style.display = 'none';
            }
        });
    });
</script>
