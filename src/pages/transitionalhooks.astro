---

<Layout
  title="100+ Viral Transitional Hooks for Social Media | Linespedia"
  description="Master social media retention with our curated library of 100+ viral video hooks. Premium transitions, visual hooks, and editing inspiration for Instagram, TikTok, and YouTube."
>
  <Navbar />
  <main class="min-h-screen bg-cream">
    <div class="poetic-gradient py-24 border-b border-indigo-50">
      <div class="container mx-auto px-4 max-w-4xl text-center">
        <Breadcrumb items={breadcrumbs} />
        <h1 class="text-5xl md:text-8xl font-serif font-black text-primary mb-8 tracking-tight leading-tight">
          Viral <span class="text-accent underline decoration-indigo-200 underline-offset-8">Hooks</span> Engine
        </h1>
        <p class="text-xl md:text-2xl text-primary/60 max-w-2xl mx-auto mb-12 font-sans italic">
          High-performance transitional hooks to keep your audience glued to the screen. 100% curated for creator excellence.
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-24 max-w-7xl">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-8">
        {hooks.map((hook) => (
          <div class="group relative bg-white rounded-3xl overflow-hidden shadow-2xl shadow-indigo-900/5 hover:shadow-primary/20 transition-all duration-700 hover:-translate-y-2 border border-indigo-50">
            {/* Video Container in Portrait 9:16 */}
            <div class="aspect-[9/16] bg-slate-950 relative overflow-hidden">
              <video 
                class="w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity duration-700 scale-105 group-hover:scale-100" 
                preload="none" 
                loop 
                muted 
                playsinline
                onmouseover="this.play()"
                onmouseout="this.pause(); this.currentTime = 0;"
              >
                <source src={`https://transitionalhooks.com/wp-content/uploads/${hook.vid.includes('2024/') ? hook.vid : '2024/09/' + hook.vid}`} type="video/mp4" />
              </video>
              
              {/* Premium Overlay */}
              <div class="absolute inset-x-0 bottom-0 p-6 bg-gradient-to-t from-black/90 via-black/40 to-transparent translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
                <span class="text-white/60 text-[10px] font-black uppercase tracking-[0.2em] mb-2 block">Premium Hook</span>
                <h3 class="text-white font-serif font-bold text-xl mb-6">{hook.title}</h3>
                <a 
                  href={hook.link} 
                  target="_blank" 
                  class="inline-flex items-center space-x-2 text-accent font-black text-xs uppercase tracking-widest group/btn"
                >
                  <span class="border-b-2 border-accent/30 group-hover/btn:border-accent transition-all">View Inspiration</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="group-hover/btn:translate-x-1 transition-transform"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                </a>
              </div>

              {/* Play Icon Placeholder */}
              <div class="absolute inset-0 flex items-center justify-center pointer-events-none group-hover:opacity-0 transition-opacity duration-300">
                 <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-md border border-white/30 flex items-center justify-center shadow-2xl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white" class="ml-1"><path d="M5 3l14 9-14 9V3z"/></svg>
                 </div>
              </div>
            </div>
            
            {/* Title for Small screens where hover might not trigger fully/clearly */}
            <div class="p-4 md:hidden">
              <h3 class="text-primary font-serif font-black text-sm">{hook.title}</h3>
            </div>
          </div>
        ))}
      </div>
      
      <div class="mt-32 p-12 bg-indigo-900 rounded-[3rem] text-center relative overflow-hidden">
        <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--color-accent)_0%,_transparent_70%)]"></div>
        <div class="relative z-10">
          <h2 class="text-3xl md:text-5xl font-serif font-black text-white mb-6">Need More Retention?</h2>
          <p class="text-indigo-200 mb-10 max-w-xl mx-auto">We are continuously syncing new hooks via our programmatic content engine. Stay tuned for updates.</p>
          <a href="/blog/" class="bg-accent text-white px-12 py-5 rounded-full font-black uppercase tracking-widest hover:scale-105 transition-transform shadow-2xl shadow-accent/20">Read the Full Guide</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style is:global>
  body {
    background-color: var(--color-cream);
  }
  /* Custom scrollbar for premium feel */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: var(--color-indigo-100);
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--color-accent);
  }
</style>
