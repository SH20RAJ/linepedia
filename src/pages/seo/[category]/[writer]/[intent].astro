---
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar.astro';
import Footer from '../../../../components/Footer.astro';
import PoemCard from '../../../../components/PoemCard.astro';
import Breadcrumb from '../../../../components/Breadcrumb.astro';
import StructuredData from '../../../../components/StructuredData.astro';
import { getCategoryPoems, getAllWriters } from '../../../../lib/cdn';
import {
  findSeoCombo,
  getIntentLabel,
  getSeoIntents,
  isSeoIntent,
  pickIntentPoems,
} from '../../../../utils/programmatic-seo';

const { category, writer, intent } = Astro.params;

if (!category || !writer || !intent || !isSeoIntent(intent)) {
  return Astro.redirect('/404');
}

const combo = await findSeoCombo(category, writer);
if (!combo) {
  return Astro.redirect('/404');
}

const allCategoryPoems = await getCategoryPoems(category);
const writerPoems = allCategoryPoems.filter((poem: any) => poem.writer === writer);
const selectedPoems = pickIntentPoems(writerPoems, intent);

if (selectedPoems.length === 0) {
  return Astro.redirect('/404');
}

const writers = await getAllWriters();
const writerData = (writers as any[]).find((w) => w.slug === writer);
const pageIntent = getIntentLabel(intent);

const pageTitle = `${combo.categoryName} ${pageIntent} by ${combo.writerName}`;
const pageDescription = `Explore ${selectedPoems.length}+ ${pageIntent.toLowerCase()} in ${combo.categoryName} by ${combo.writerName}. SEO-friendly, copy-ready poetry lines for sharing.`;
const canonicalPath = `/seo/${category}/${writer}/${intent}/`;

const breadcrumbs = [
  { name: 'Categories', href: '/categories/' },
  { name: combo.categoryName, href: `/${combo.categorySlug}/` },
  { name: combo.writerName, href: `/${combo.writerSlug}/` },
  { name: pageIntent, href: canonicalPath },
];

const intentLinks = getSeoIntents().map((item) => ({
  intent: item,
  label: getIntentLabel(item),
  href: `/seo/${category}/${writer}/${item}/`,
}));
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={new URL(canonicalPath, Astro.site).toString()}
>
  <StructuredData
    type="collection"
    title={pageTitle}
    description={pageDescription}
    url={canonicalPath}
    breadcrumbs={breadcrumbs.map((crumb) => ({ name: crumb.name, url: crumb.href }))}
  />

  <Navbar />

  <main class="min-h-screen py-20 px-4">
    <div class="container mx-auto max-w-7xl">
      <Breadcrumb items={breadcrumbs} />

      <header class="mt-8 mb-10 rounded-[2rem] border border-indigo-100 bg-white p-8 md:p-12">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-indigo-500">Programmatic SEO Collection</p>
        <h1 class="mt-3 text-3xl md:text-5xl font-serif font-black text-primary">{pageTitle}</h1>
        <p class="mt-4 text-primary/70 max-w-3xl">{pageDescription}</p>
        <div class="mt-6 flex flex-wrap gap-3">
          {intentLinks.map((tab) => (
            <a
              href={tab.href}
              class={`px-4 py-2 rounded-full text-xs font-bold border transition-all ${tab.intent === intent ? 'bg-primary text-white border-primary' : 'bg-white text-primary/70 border-indigo-100 hover:border-primary hover:text-primary'}`}
            >
              {tab.label}
            </a>
          ))}
        </div>
      </header>

      <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {selectedPoems.map((poem: any) => (
          <PoemCard
            id={poem.id}
            slug={poem.slug}
            content={poem.content}
            writer={poem.writer}
            writerName={writerData?.name || combo.writerName}
          />
        ))}
      </section>
    </div>
  </main>

  <Footer />
</Layout>
