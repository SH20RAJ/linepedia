---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PoemCard from '../components/PoemCard.astro';
import Search from '../components/Search.astro';
import { Quote, Search as SearchIcon, Filter, Sparkles } from 'lucide-astro';

import Pagination from '../components/Pagination.astro';

const writers = await getAllWriters();
const categories = await getAllCategories();
const poemsData = await getFeaturedPoems();

const pageSize = 12;
const currentPage = parseInt(Astro.url.searchParams.get('page') || '1');
const totalPages = Math.ceil(poemsData.length / pageSize);

const featuredPoems = poemsData.slice((currentPage - 1) * pageSize, currentPage * pageSize);
---

<Layout title="Explore Poetry — Linespedia" description="Discover the world's best poetry collection. Filter by mood, writer, or theme.">
	<Navbar />
	
	<main class="min-h-screen poetic-gradient py-20">
		<div class="container mx-auto px-4">
			<div class="max-w-4xl mx-auto text-center mb-16">
				<h1 class="text-5xl md:text-7xl font-serif font-black text-primary mb-6">Discovery</h1>
				<p class="text-xl text-primary/50">Search through 75,000+ curated lines and poems.</p>
			</div>

			<div class="max-w-3xl mx-auto mb-20">
				<Search />
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-4 gap-12">
				{/* Sidebar Filters */}
				<aside class="space-y-10">
					<div>
						<h3 class="flex items-center space-x-3 text-sm font-bold uppercase tracking-[0.2em] text-primary/40 mb-6">
							<Filter size={16} />
							<span>Top Categories</span>
						</h3>
						<div class="flex flex-wrap gap-2">
							{categories.slice(0, 15).map((cat: any) => (
								<a href={`/${cat.slug}/`} class="px-4 py-2 bg-white border border-indigo-50 rounded-full text-sm font-medium text-primary hover:bg-primary hover:text-white transition-all">
									{cat.name}
								</a>
							))}
						</div>
					</div>

					<div>
						<h3 class="flex items-center space-x-3 text-sm font-bold uppercase tracking-[0.2em] text-primary/40 mb-6">
							<Sparkles size={16} />
							<span>Popular Poets</span>
						</h3>
						<div class="space-y-4">
							{writers.slice(0, 8).map((writer: any) => (
								<a href={`/${writer.slug}/`} class="flex items-center space-x-4 group">
									<img src={writer.photo} class="w-10 h-10 rounded-full object-cover grayscale group-hover:grayscale-0 transition-all" />
									<span class="font-bold text-primary group-hover:text-accent transition-colors">{writer.name}</span>
								</a>
							))}
						</div>
					</div>
				</aside>

				{/* Results Grid */}
				<div class="lg:col-span-3">
					<div class="flex items-center justify-between mb-8">
						<h2 class="text-2xl font-serif font-black text-primary">Featured Selection</h2>
						<span class="text-sm text-primary/40 font-bold">Page {currentPage} of {totalPages}</span>
					</div>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
						{featuredPoems.map((poem: any) => (
							<PoemCard
								id={poem.id}
								slug={poem.slug}
								content={poem.content.slice(0, 200)}
								writer={poem.writer}
								writerName={writers.find((w: any) => w.slug === poem.writer)?.name || poem.writer}
							/>
						))}
					</div>

					<Pagination 
						currentPage={currentPage} 
						totalPages={totalPages} 
						baseUrl="/explore/" 
					/>
				</div>
			</div>
		</div>
	</main>
	<Footer />
</Layout>
