---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PoemCard from '../components/PoemCard.astro';
import StructuredData from '../components/StructuredData.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import AIPanel from '../components/AIPanel.astro';
import { Share2, Copy, Heart, BookOpen, Quote, ChevronRight, Bookmark, Download, Sparkles } from 'lucide-astro';

import { 
    getPoem, 
    getAllWriters, 
    getAllCategories, 
    getAllCollections, 
    getPoemIdBySlug,
    getWriterPoems,
    getCategoryPoems,
    getRelatedPoems,
    getPosterUrl,
    hasPoster
} from '../lib/cdn';

// export const prerender = true;

export async function getStaticPaths() {
    const CDN_BASE = 'https://cdn.jsdelivr.net/gh/BluredCodes/linespedia-data@main';
    const res = await fetch(`${CDN_BASE}/metadata/v1/slug-map.json`);
    const slugMap = await res.json() as Record<string, string>;
    const writers = await (await fetch(`${CDN_BASE}/metadata/v1/writers.json`)).json() as any[];
    const categories = await (await fetch(`${CDN_BASE}/metadata/v1/categories.json`)).json() as any[];
    const collections = await (await fetch(`${CDN_BASE}/metadata/v1/collections.json`)).json() as any[];

    const paths: any[] = [];

    // 1. Line Paths
    Object.keys(slugMap).forEach(slug => {
        paths.push({ params: { slug: `line/${slug}` } });
    });

    // 2. Writer Paths
    writers.forEach((w: any) => {
        paths.push({ params: { slug: w.slug } });
    });

    // 3. Category Paths
    categories.forEach((c: any) => {
        paths.push({ params: { slug: c.slug } });
    });

    // 4. Collection Paths
    collections.forEach((c: any) => {
        paths.push({ params: { slug: c.slug } });
    });

    return paths;
}

const { slug } = Astro.params;

let error = null;
let pageData = null;

async function getPageData(pathSlug: string | undefined) {
    try {
        if (!pathSlug) return null;

        const writers = await getAllWriters();
        const categories = await getAllCategories();
        const collections = await getAllCollections();

        // 1. Line Page
        if (pathSlug.startsWith('line/')) {
            const lineSlug = pathSlug.replace('line/', '');
            const id = await getPoemIdBySlug(lineSlug);
            
            if (id) {
                const data = await getPoem(id);
                if (data) {
                    const writerSlug = typeof data.writer === 'string' ? slugify(data.writer) : '';
                    const related = await getRelatedPoems(writerSlug, data.category || []);
                    
                    return {
                        type: 'line',
                        data: data,
                        writer: writers.find((w: any) => w.slug === writerSlug),
                        allWriters: writers,
                        poems: related.filter(p => p.slug !== data.slug)
                    };
                }
            }
        }

        // 2. Writer Page
        const writer = writers.find((w: any) => w.slug === pathSlug);
        if (writer) {
            const writerPoems = await getWriterPoems(writer.slug);
            return { type: 'writer', data: writer, poems: writerPoems, allWriters: writers };
        }

        // 3. Category Page
        const category = categories.find((c: any) => c.slug === pathSlug);
        if (category) {
            const categoryPoems = await getCategoryPoems(category.slug);
            return { type: 'category', data: category, poems: categoryPoems, allWriters: writers };
        }
        
        // 4. Collection Page
        const collection = collections.find((c: any) => c.slug === pathSlug);
        if (collection) {
            const collectionPoems = await getCategoryPoems(collection.slug);
            return { type: 'collection', data: collection, poems: collectionPoems, allWriters: writers };
        }

        return null;
    } catch (e: any) {
        throw e;
    }
}

function slugify(text: string) {
    return text.toLowerCase().trim().replace(/\s+/g, '-').replace(/[^\w-]+/g, '').replace(/--+/g, '-');
}

pageData = await getPageData(slug);

if (!pageData) return Astro.redirect('/404');

const { type, data, writer, poems = [], allWriters = [] } = (pageData || {}) as any;

const breadcrumbs: any[] = [];
if (type === 'line' && data) {
    breadcrumbs.push({ name: 'Poetry', href: '/explore/' });
    if (writer) breadcrumbs.push({ name: writer.name, href: `/${writer.slug}/` });
    breadcrumbs.push({ name: data.title, href: `/line/${data.slug}/` });
} else if (type === 'writer' && data) {
    breadcrumbs.push({ name: 'Writers', href: '/writers/' });
    breadcrumbs.push({ name: data.name, href: `/${data.slug}/` });
} else if (type === 'category' && data) {
    breadcrumbs.push({ name: 'Categories', href: '/categories/' });
    breadcrumbs.push({ name: data.name, href: `/${data.slug}/` });
} else if (type === 'collection' && data) {
    breadcrumbs.push({ name: 'Collections', href: '/collections/' });
    breadcrumbs.push({ name: data.name, href: `/${data.slug}/` });
}

function getCTRTitle() {
    if (!data) return "Poetry | Linespedia";
    if (type === 'line') return `${data.title} — Poetry Lines | Linespedia`;
    if (type === 'writer') return `${data.name} Poetry — Best Lines & Shayari Collection`;
    if (type === 'category') return `Best ${data.name} Lines — Copy Paste ${new Date().getFullYear()}`;
    if (type === 'collection') return `${data.name} — Top Lines for Instagram & WhatsApp`;
    return data.name || "Poetry";
}

function getDescription() {
    if (!data) return "Explore the best lines on Linespedia.";
    if (type === 'line') return `${data.content?.slice(0, 140)}... Read meaning and context from ${writer?.name || 'the poet'}.`;
    if (type === 'writer') return data.bio;
    return data.seoIntro || data.description;
}

const posterUrl = type === 'line' ? getPosterUrl(data.slug) : null;
---

<Layout title={getCTRTitle()} description={getDescription()} type={type === 'line' ? 'article' : 'website'}>
    {type === 'line' && (
        <StructuredData
            type="line"
            title={getCTRTitle()}
            description={getDescription()}
            url={Astro.url.pathname}
            authorName={writer?.name}
            datePublished={data.createdAt}
            breadcrumbs={breadcrumbs.map((b: any) => ({ name: b.name, url: b.href }))}
        />
    )}

    <Navbar />
    
    <main class="min-h-screen poetic-gradient">

        {/* ========== LINE PAGE ========== */}
        {type === 'line' && (
            <div class="container mx-auto px-4 py-12 md:py-32 max-w-5xl animate-in fade-in slide-in-from-bottom-8 duration-1000">
                <Breadcrumb items={breadcrumbs} />
                
                <article class="mt-8 bg-white/70 backdrop-blur-2xl border border-white/40 rounded-[4rem] p-10 md:p-20 shadow-2xl relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-12 opacity-[0.03] text-primary group-hover:scale-110 transition-transform duration-700">
                        <Quote size={120} />
                    </div>
                    
                    <div class="relative z-10 flex flex-col items-center text-center">
                        <h1 class="text-xs font-bold uppercase tracking-[0.4em] text-primary/30 mb-8 md:mb-12">Poetic Insight</h1>
                        
                        <blockquote class="text-3xl md:text-6xl font-serif font-black text-primary leading-tight md:leading-snug mb-16 selection:bg-accent/20 max-w-4xl mx-auto">
                            <p class="whitespace-pre-line drop-shadow-sm italic">{data.content}</p>
                        </blockquote>

                        <div class="flex flex-wrap justify-center gap-6 mb-16">
                            <button id="copy-btn" class="bg-primary text-white px-10 py-5 rounded-full font-bold flex items-center space-x-3 hover:bg-primary/90 hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-primary/20">
                                <Copy size={20} />
                                <span>Copy Line</span>
                            </button>
                            <button id="pin-btn" class="bg-[#E60023] text-white px-10 py-5 rounded-full font-bold flex items-center space-x-3 hover:bg-[#ad001a] hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-red-500/20">
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-1.14 0-2.22-.23-3.21-.64.45-.89 1.11-2.47 1.37-3.57.14-.58.72-2.97.72-2.97.38.72 1.48 1.33 2.65 1.33 3.49 0 6.03-3.2 6.03-7.18 0-3.81-3.11-6.67-7.18-6.67C8.09 2.3 4 5.7 4 10.12c0 2.42 1.27 4.32 3.29 5.08.17.07.33 0 .38-.18.04-.14.13-.49.17-.64.06-.21.04-.28-.12-.46-.35-.4-.64-1.13-.64-1.82 0-2.63 1.97-5.17 5.32-5.17 2.9 0 4.94 1.97 4.94 4.78 0 3.19-1.61 5.41-3.71 5.41-1.16 0-2.02-.96-1.74-2.13.33-1.4 .97-2.91.97-3.92 0-.9-.48-1.65-1.49-1.65-1.18 0-2.13 1.22-2.13 2.86 0 1.04.35 1.75.35 1.75s-1.2 5.11-1.41 5.96c-.21.86-.12 2.08-.04 2.87A9.96 9.96 0 012 12c0-5.52 4.48-10 10-10s10 4.48 10 10-4.48 10-10 10z"/></svg>
                                <span>Pin</span>
                            </button>
                            <button id="share-btn" class="bg-white border-2 border-primary text-primary px-10 py-5 rounded-full font-bold flex items-center space-x-3 hover:bg-indigo-50 hover:scale-105 active:scale-95 transition-all">
                                <Share2 size={20} />
                                <span>Share</span>
                            </button>
                        </div>

                        {/* AIPanel integration */}
                        <AIPanel content={data.content} title={data.title} writer={writer?.name || data.writer} />

                        {/* Meaning & Context */}
                        <div class="w-full text-left bg-indigo-50/40 backdrop-blur-md rounded-[2.5rem] p-10 md:p-14 border border-indigo-100/30 mt-12">
                            <h2 class="font-bold text-xs uppercase tracking-[0.3em] text-primary/40 mb-8 flex items-center space-x-3">
                                <BookOpen size={18} />
                                <span>Meaning & Deep Context</span>
                            </h2>
                            <div class="prose prose-indigo prose-lg text-primary/70 leading-relaxed space-y-6 max-w-none font-medium">
                                <p class="text-primary/80 italic">"{data.content?.split('\n')[0]}..."</p>
                                <p>{data.meaning || `This powerful line by ${writer?.name || 'the poet'} explores the delicate balance of emotion and expression. It serves as a testament to the enduring power of verse.`}</p>
                            </div>
                        </div>

                        {/* Digital Poster - only if it exists */}
                        {posterUrl && (
                            <div class="mt-20 w-full pt-16 border-t border-indigo-50/50 text-left">
                                <div class="flex items-end justify-between mb-12">
                                    <div>
                                        <h3 class="text-3xl font-serif font-black text-primary mb-2">Visual Discovery</h3>
                                        <p class="text-primary/40">Download or share as a digital poster.</p>
                                    </div>
                                    <a href={posterUrl} download class="hidden md:flex items-center space-x-3 px-8 py-4 bg-white border-2 border-primary/10 rounded-full text-sm font-bold text-primary hover:bg-primary hover:text-white transition-all">
                                        <Download size={20} />
                                        <span>Download</span>
                                    </a>
                                </div>
                                <div class="rounded-3xl border border-indigo-50/50 overflow-hidden shadow-2xl max-w-lg mx-auto md:mx-0">
                                    <img src={posterUrl} alt={`${data.title} Poster`} class="w-full object-contain" loading="lazy" />
                                </div>
                            </div>
                        )}
                    </div>
                </article>

                {/* Related Lines */}
                {poems.length > 0 && (
                    <div class="mt-24">
                        <h3 class="text-2xl font-serif font-black text-primary mb-10 flex items-center space-x-4">
                            <Sparkles class="text-accent" size={24} />
                            <span>Related Poetic Lines</span>
                        </h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            {poems.map((poem: any) => (
                                <PoemCard id={poem.id} slug={poem.slug} content={poem.content} writer={poem.writer} writerName={poem.writer?.replace(/-/g, ' ')} />
                            ))}
                        </div>
                    </div>
                )}
                
                {/* Writer Profile */}
                {writer && (
                    <a href={`/${writer.slug}`} class="mt-16 p-10 bg-white border border-indigo-50 rounded-[3rem] shadow-xl flex flex-col md:flex-row items-center space-y-8 md:space-y-0 md:space-x-10 hover:shadow-2xl transition-all duration-500 block">
                        <div class="w-32 h-32 md:w-40 md:h-40 flex-shrink-0 rounded-3xl overflow-hidden border-4 border-indigo-50">
                            <img src={writer.photo} class="w-full h-full object-cover" alt={writer.name} loading="lazy" />
                        </div>
                        <div class="flex-grow text-center md:text-left">
                            <h3 class="text-2xl font-serif font-black text-primary mb-3">About {writer.name}</h3>
                            <p class="text-primary/60 leading-relaxed mb-6">{writer.bio?.slice(0, 180)}...</p>
                            <span class="inline-flex items-center space-x-3 text-accent font-bold uppercase tracking-widest text-sm">
                                <span>Full Bibliography</span>
                                <ChevronRight size={18} />
                            </span>
                        </div>
                    </a>
                )}
            </div>
        )}

        {/* ========== WRITER / CATEGORY / COLLECTION PAGES (unchanged functionally, but improved spacing) ========== */}
        {type !== 'line' && (
            <div class={type === 'writer' ? 'pt-24 pb-40' : 'py-24'}>
                <div class="container mx-auto px-4 text-center max-w-4xl">
                    <Breadcrumb items={breadcrumbs} />
                    {type === 'writer' && <img src={data.photo} class="w-40 h-40 md:w-56 md:h-56 rounded-[3rem] object-cover shadow-2xl border-4 border-white mb-8 mt-6 mx-auto" alt={data.name} loading="lazy" />}
                    <h1 class="text-4xl md:text-7xl font-serif font-black text-primary mb-6 mt-4">{data.name}</h1>
                    <p class="text-lg md:text-xl text-primary/60 leading-relaxed max-w-3xl mx-auto">{data.bio || data.seoIntro || data.description}</p>
                    <div class="mt-8 text-sm text-primary/40 font-bold uppercase tracking-widest">{poems.length} Lines Found</div>
                </div>
                
                <div class="container mx-auto px-4 mt-20">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 pb-24">
                        {poems.map((poem: any) => (
                            <PoemCard id={poem.id} slug={poem.slug} content={poem.content} writer={poem.writer} writerName={type === 'writer' ? data.name : poem.writer?.replace(/-/g, ' ')} />
                        ))}
                    </div>
                </div>
            </div>
        )}
    </main>

    <Footer />
</Layout>

<script>
    const copyBtn = document.getElementById('copy-btn');
    const pinBtn = document.getElementById('pin-btn');
    const shareBtn = document.getElementById('share-btn');

    const poemContent = document.querySelector('blockquote p')?.textContent || '';
    const currentUrl = window.location.href;
    const posterImg = document.querySelector('img[alt$="Poster"]');
    const imageUrl = posterImg ? `${window.location.origin}${posterImg.getAttribute('src') || ''}` : '';

    function doCopy(btn: any) {
        navigator.clipboard.writeText(poemContent).then(() => {
            const span = btn?.querySelector('span');
            if (span) {
                const old = span.textContent;
                span.textContent = 'Copied!';
                setTimeout(() => { span.textContent = old; }, 2000);
            }
        });
    }

    function doPin() {
        const pinUrl = `https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(currentUrl)}&media=${encodeURIComponent(imageUrl)}&description=${encodeURIComponent(poemContent.slice(0, 200))}`;
        window.open(pinUrl, '_blank');
    }

    function doShare() {
        if (navigator.share) {
            navigator.share({ title: document.title, text: poemContent, url: currentUrl });
        } else {
            navigator.clipboard.writeText(currentUrl);
            alert("Link copied to clipboard!");
        }
    }

    copyBtn?.addEventListener('click', () => doCopy(copyBtn));
    pinBtn?.addEventListener('click', doPin);
    shareBtn?.addEventListener('click', doShare);
</script>

<style>
    .poetic-gradient {
        background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.05), transparent 40%),
                    radial-gradient(circle at bottom left, rgba(236, 72, 153, 0.05), transparent 40%),
                    #fdfcf7;
    }
</style>
