---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PoemCard from "../components/PoemCard.astro";
import StructuredData from "../components/StructuredData.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import AIPanel from "../components/AIPanel.astro";
import {
  Share2,
  Copy,
  Heart,
  BookOpen,
  Quote,
  ChevronRight,
  Bookmark,
  Download,
  Sparkles,
} from "lucide-astro";

import {
  getPoem,
  getAllWriters,
  getAllCategories,
  getAllCollections,
  getPoemIdBySlug,
  getWriterPoems,
  getCategoryPoems,
  getRelatedPoems,
  getPosterUrl,
  hasPoster,
} from "../lib/cdn";

// export const prerender = true;

export async function getStaticPaths() {
  const CDN_BASE =
    "https://cdn.jsdelivr.net/gh/BluredCodes/linespedia-data@main";
  const res = await fetch(`${CDN_BASE}/metadata/v1/slug-map.json`);
  const slugMap = (await res.json()) as Record<string, string>;
  const writers = (await (
    await fetch(`${CDN_BASE}/metadata/v1/writers.json`)
  ).json()) as any[];
  const categories = (await (
    await fetch(`${CDN_BASE}/metadata/v1/categories.json`)
  ).json()) as any[];
  const collections = (await (
    await fetch(`${CDN_BASE}/metadata/v1/collections.json`)
  ).json()) as any[];

  const paths: any[] = [];

  // 1. Line Paths
  Object.keys(slugMap).forEach((slug) => {
    paths.push({ params: { slug: `line/${slug}` } });
  });

  // 2. Writer Paths
  writers.forEach((w: any) => {
    paths.push({ params: { slug: w.slug } });
  });

  // 3. Category Paths
  categories.forEach((c: any) => {
    paths.push({ params: { slug: c.slug } });
  });

  // 4. Collection Paths
  collections.forEach((c: any) => {
    paths.push({ params: { slug: c.slug } });
  });

  return paths;
}

const { slug } = Astro.params;

let error = null;
let pageData = null;

async function getPageData(pathSlug: string | undefined) {
  try {
    if (!pathSlug) return null;

    const writers = await getAllWriters();
    const categories = await getAllCategories();
    const collections = await getAllCollections();

    // 1. Line Page
    if (pathSlug.startsWith("line/")) {
      // AllPoetry special route: line/ap/writer-slug/poem-slug
      if (pathSlug.startsWith("line/ap/")) {
        const parts = pathSlug.replace("line/ap/", "").split("/");
        const writerSlug = parts[0];
        const poemSlug = parts[parts.length - 1]; // Handle potential trailing slashes

        const { getAllPoetryPoem, getPoetryWriterPoems } =
          await import("../lib/cdn");
        const data = await getAllPoetryPoem(writerSlug, poemSlug);

        if (data) {
          const authorPoems = await getPoetryWriterPoems(writerSlug);
          return {
            type: "line",
            data: data,
            writer: {
              name: data.writer,
              slug: `poet/${writerSlug}`,
              photo: `https://ui-avatars.com/api/?name=${encodeURIComponent(data.writer)}&background=6366f1&color=fff&size=128`,
              bio: `Explore the profound poetry and moving lines of ${data.writer}. This collection features a curated selection of their work from our extended library.`,
            },
            allWriters: writers,
            poems: authorPoems
              .filter((p: any) => p.slug !== poemSlug)
              .slice(0, 6),
          };
        }
      }

      let lineSlug = pathSlug.replace("line/", "");

      // Remove trailing slash for lookup if any
      if (lineSlug.endsWith("/")) lineSlug = lineSlug.slice(0, -1);

      let id = await getPoemIdBySlug(lineSlug);

      // Fallback: If not found by slug, check if the slug ends with a numeric ID
      if (!id) {
        const parts = lineSlug.split("-");
        const possibleId = parts[parts.length - 1];
        if (/^\d+$/.test(possibleId)) {
          id = possibleId;
        }
      }

      if (id) {
        const data = await getPoem(id);
        if (data) {
          const writerSlug =
            typeof data.writer === "string" ? slugify(data.writer) : "";

          // Permanent Redirect if the slug is not canonical
          if (data.slug !== lineSlug) {
            return { redirect: `/line/${data.slug}/` };
          }

          const related = await getRelatedPoems(
            writerSlug,
            data.category || [],
          );

          return {
            type: "line",
            data: data,
            writer: writers.find((w: any) => w.slug === writerSlug),
            allWriters: writers,
            poems: related.filter((p) => p.slug !== data.slug),
          };
        }
      }
    }

    // 2. Writer Page
    const writer = writers.find((w: any) => w.slug === pathSlug);
    if (writer) {
      const writerPoems = await getWriterPoems(writer.slug);
      return {
        type: "writer",
        data: writer,
        poems: writerPoems,
        allWriters: writers,
      };
    }

    // 3. Category Page
    const category = categories.find((c: any) => c.slug === pathSlug);
    if (category) {
      const categoryPoems = await getCategoryPoems(category.slug);
      return {
        type: "category",
        data: category,
        poems: categoryPoems,
        allWriters: writers,
      };
    }

    // 4. Collection Page
    const collection = collections.find((c: any) => c.slug === pathSlug);
    if (collection) {
      const collectionPoems = await getCategoryPoems(collection.slug);
      return {
        type: "collection",
        data: collection,
        poems: collectionPoems,
        allWriters: writers,
      };
    }

    // 5. AllPoetry Poet Page
    if (pathSlug.startsWith("poet/")) {
      const writerSlug = pathSlug.replace("poet/", "").replace(/\/$/, "");
      const { getPoetryWriterPoems, getAllPoetryWriters } =
        await import("../lib/cdn");
      const poetryWriters = await getAllPoetryWriters();
      const poet = poetryWriters.find((w: any) => w.slug === writerSlug);

      if (poet) {
        const poems = await getPoetryWriterPoems(writerSlug);
        return {
          type: "writer",
          data: {
            name: poet.name,
            slug: writerSlug,
            photo: `https://api.dicebear.com/7.x/avataaars/svg?seed=${writerSlug}`,
            bio: `Explore the profound poetry and moving lines of ${poet.name}. This collection features a curated selection of their work from our extended library.`,
          },
          poems: poems,
          allWriters: writers,
        };
      }
    }

    return null;
  } catch (e: any) {
    throw e;
  }
}

function slugify(text: string) {
  return text
    .toLowerCase()
    .trim()
    .replace(/\s+/g, "-")
    .replace(/[^\w-]+/g, "")
    .replace(/--+/g, "-");
}

pageData = await getPageData(slug);

if (!pageData) return Astro.redirect("/404/");
if (pageData.redirect) return Astro.redirect(pageData.redirect, 301);

const {
  type,
  data,
  writer,
  poems = [],
  allWriters = [],
} = (pageData || {}) as any;
const allCategories = await getAllCategories();

const currentWriterSlug =
  writer?.slug?.replace("poet/", "") ||
  (type === "writer" ? data.slug?.replace("poet/", "") : "");

function getCategorySlug(catName: string) {
  const cat = allCategories.find(
    (c: any) => c.name.toLowerCase() === catName.toLowerCase(),
  );
  return cat ? cat.slug : slugify(catName);
}

const breadcrumbs: any[] = [];
const lang = Astro.url.searchParams.get("lang") || "en";

if (type === "line" && data) {
  breadcrumbs.push({ name: "Poetry", href: "/explore/" });
  if (writer) breadcrumbs.push({ name: writer.name, href: `/${writer.slug}/` });
  breadcrumbs.push({ name: data.title, href: `/line/${data.slug}/` });
} else if (type === "writer" && data) {
  breadcrumbs.push({ name: "Writers", href: "/writers/" });
  breadcrumbs.push({ name: data.name, href: `/${data.slug}/` });
} else if (type === "category" && data) {
  breadcrumbs.push({ name: "Categories", href: "/categories/" });
  breadcrumbs.push({ name: data.name, href: `/${data.slug}/` });
} else if (type === "collection" && data) {
  breadcrumbs.push({ name: "Collections", href: "/collections/" });
  breadcrumbs.push({ name: data.name, href: `/${data.slug}/` });
}

function getCTRTitle() {
  if (!data) return "Poetry | Linespedia";
  if (type === "line") return `${data.title} — Poetry Lines | Linespedia`;
  if (type === "writer")
    return `${data.name} Poetry — Best Lines & Shayari Collection`;
  if (type === "category")
    return `Best ${data.name} Lines — Copy Paste ${new Date().getFullYear()}`;
  if (type === "collection")
    return `${data.name} — Top Lines for Instagram & WhatsApp`;
  return data.name || "Poetry";
}

function getDescription() {
  if (!data) return "Explore the best lines on Linespedia.";
  if (type === "line")
    return `${data.content?.slice(0, 140)}... Read meaning and context from ${writer?.name || "the poet"}.`;
  if (type === "writer") return data.bio;
  return data.seoIntro || data.description;
}

const posterUrl = type === "line" ? getPosterUrl(data.slug) : null;
---

<Layout
  title={getCTRTitle()}
  description={getDescription()}
  type={type === "line" ? "article" : "website"}
>
  <link
    slot="head"
    rel="alternate"
    hreflang="es"
    href={`${Astro.url.origin}${Astro.url.pathname}?lang=es`}
  />
  <link
    slot="head"
    rel="alternate"
    hreflang="fr"
    href={`${Astro.url.origin}${Astro.url.pathname}?lang=fr`}
  />
  <link
    slot="head"
    rel="alternate"
    hreflang="de"
    href={`${Astro.url.origin}${Astro.url.pathname}?lang=de`}
  />
  <link
    slot="head"
    rel="alternate"
    hreflang="hi"
    href={`${Astro.url.origin}${Astro.url.pathname}?lang=hi`}
  />
  <link
    slot="head"
    rel="alternate"
    hreflang="ar"
    href={`${Astro.url.origin}${Astro.url.pathname}?lang=ar`}
  />
  <link
    slot="head"
    rel="alternate"
    hreflang="zh"
    href={`${Astro.url.origin}${Astro.url.pathname}?lang=zh`}
  />
  <meta slot="head" name="lang-trigger" content={lang} />

  {
    type === "line" && (
      <StructuredData
        type="line"
        title={getCTRTitle()}
        description={getDescription()}
        url={Astro.url.pathname}
        authorName={writer?.name}
        datePublished={data.createdAt}
        breadcrumbs={breadcrumbs.map((b: any) => ({
          name: b.name,
          url: b.href,
        }))}
      />
    )
  }

  <Navbar />

  <main class="min-h-screen poetic-gradient">
    {/* ========== LINE PAGE ========== */}
    {
      type === "line" && (
        <div class="container mx-auto px-4 py-12 md:py-32 max-w-7xl animate-in fade-in slide-in-from-bottom-8 duration-1000">
          <Breadcrumb items={breadcrumbs} />

          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mt-8">
            {/* Main Content Column */}
            <div class="lg:col-span-8 space-y-12">
              <article class="bg-white/70 backdrop-blur-2xl border border-white/40 rounded-[4rem] p-10 md:p-16 shadow-2xl relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-12 opacity-[0.03] text-primary group-hover:scale-110 transition-transform duration-700">
                  <Quote size={120} />
                </div>

                <div class="relative z-10">
                  <h1 class="text-xs font-bold uppercase tracking-[0.4em] text-primary/30 mb-8 md:mb-12 text-center">
                    Poetic Insight
                  </h1>

                  <blockquote class="text-2xl md:text-4xl font-serif font-black text-primary leading-tight md:leading-snug mb-16 selection:bg-accent/20 max-w-4xl mx-auto text-center">
                    <p class="whitespace-pre-line drop-shadow-sm italic">
                      {data.content}
                    </p>
                  </blockquote>

                  <div class="flex flex-wrap justify-center gap-4 mb-16">
                    <button
                      id="copy-btn"
                      class="bg-primary text-white px-8 py-4 rounded-full text-sm font-bold flex items-center space-x-3 hover:bg-primary/90 hover:scale-105 active:scale-95 transition-all shadow-xl shadow-primary/10"
                    >
                      <Copy size={18} />
                      <span>Copy</span>
                    </button>
                    <button
                      id="whatsapp-btn"
                      class="bg-[#25D366] text-white px-8 py-4 rounded-full text-sm font-bold flex items-center space-x-3 hover:bg-[#128C7E] hover:scale-105 active:scale-95 transition-all shadow-xl shadow-green-500/10"
                    >
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 32 32"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          fill-rule="evenodd"
                          clip-rule="evenodd"
                          d="M16 31C23.732 31 30 24.732 30 17C30 9.26801 23.732 3 16 3C8.26801 3 2 9.26801 2 17C2 19.5109 2.661 21.8674 3.81847 23.905L2 31L9.31486 29.3038C11.3014 30.3854 13.5789 31 16 31ZM16 28.8462C22.5425 28.8462 27.8462 23.5425 27.8462 17C27.8462 10.4576 22.5425 5.15385 16 5.15385C9.45755 5.15385 4.15385 10.4576 4.15385 17C4.15385 19.5261 4.9445 21.8675 6.29184 23.7902L5.23077 27.7692L9.27993 26.7569C11.1894 28.0746 13.5046 28.8462 16 28.8462Z"
                          fill="#BFC8D0"
                        />
                        <path
                          d="M28 16C28 22.6274 22.6274 28 16 28C13.4722 28 11.1269 27.2184 9.19266 25.8837L5.09091 26.9091L6.16576 22.8784C4.80092 20.9307 4 18.5589 4 16C4 9.37258 9.37258 4 16 4C22.6274 4 28 9.37258 28 16Z"
                          fill="url(#paint0_linear_87_7264)"
                        />
                        <path
                          fill-rule="evenodd"
                          clip-rule="evenodd"
                          d="M16 30C23.732 30 30 23.732 30 16C30 8.26801 23.732 2 16 2C8.26801 2 2 8.26801 2 16C2 18.5109 2.661 20.8674 3.81847 22.905L2 30L9.31486 28.3038C11.3014 29.3854 13.5789 30 16 30ZM16 27.8462C22.5425 27.8462 27.8462 22.5425 27.8462 16C27.8462 9.45755 22.5425 4.15385 16 4.15385C9.45755 4.15385 4.15385 9.45755 4.15385 16C4.15385 18.5261 4.9445 20.8675 6.29184 22.7902L5.23077 26.7692L9.27993 25.7569C11.1894 27.0746 13.5046 27.8462 16 27.8462Z"
                          fill="white"
                        />
                        <path
                          d="M12.5 9.49989C12.1672 8.83131 11.6565 8.8905 11.1407 8.8905C10.2188 8.8905 8.78125 9.99478 8.78125 12.05C8.78125 13.7343 9.52345 15.578 12.0244 18.3361C14.438 20.9979 17.6094 22.3748 20.2422 22.3279C22.875 22.2811 23.4167 20.0154 23.4167 19.2503C23.4167 18.9112 23.2062 18.742 23.0613 18.696C22.1641 18.2654 20.5093 17.4631 20.1328 17.3124C19.7563 17.1617 19.5597 17.3656 19.4375 17.4765C19.0961 17.8018 18.4193 18.7608 18.1875 18.9765C17.9558 19.1922 17.6103 19.083 17.4665 19.0015C16.9374 18.7892 15.5029 18.1511 14.3595 17.0426C12.9453 15.6718 12.8623 15.2001 12.5959 14.7803C12.3828 14.4444 12.5392 14.2384 12.6172 14.1483C12.9219 13.7968 13.3426 13.254 13.5313 12.9843C13.7199 12.7145 13.5702 12.305 13.4803 12.05C13.0938 10.953 12.7663 10.0347 12.5 9.49989Z"
                          fill="white"
                        />
                        <defs>
                          <linearGradient
                            id="paint0_linear_87_7264"
                            x1="26.5"
                            y1="7"
                            x2="4"
                            y2="28"
                            gradientUnits="userSpaceOnUse"
                          >
                            <stop stop-color="#5BD066" />
                            <stop offset="1" stop-color="#27B43E" />
                          </linearGradient>
                        </defs>
                      </svg>{" "}
                      <span>WhatsApp</span>
                    </button>
                    <button
                      id="pin-btn"
                      class="bg-[#E60023] text-white px-8 py-4 rounded-full text-sm font-bold flex items-center space-x-3 hover:bg-[#ad001a] hover:scale-105 active:scale-95 transition-all shadow-xl shadow-red-500/10"
                    >
                      <svg
                        viewBox="0 0 24 24"
                        width="18"
                        height="18"
                        fill="currentColor"
                      >
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-1.14 0-2.22-.23-3.21-.64.45-.89 1.11-2.47 1.37-3.57.14-.58.72-2.97.72-2.97.38.72 1.48 1.33 2.65 1.33 3.49 0 6.03-3.2 6.03-7.18 0-3.81-3.11-6.67-7.18-6.67C8.09 2.3 4 5.7 4 10.12c0 2.42 1.27 4.32 3.29 5.08.17.07.33 0 .38-.18.04-.14.13-.49.17-.64.06-.21.04-.28-.12-.46-.35-.4-.64-1.13-.64-1.82 0-2.63 1.97-5.17 5.32-5.17 2.9 0 4.94 1.97 4.94 4.78 0 3.19-1.61 5.41-3.71 5.41-1.16 0-2.02-.96-1.74-2.13.33-1.4 .97-2.91.97-3.92 0-.9-.48-1.65-1.49-1.65-1.18 0-2.13 1.22-2.13 2.86 0 1.04.35 1.75.35 1.75s-1.2 5.11-1.41 5.96c-.21.86-.12 2.08-.04 2.87A9.96 9.96 0 012 12c0-5.52 4.48-10 10-10s10 4.48 10 10-4.48 10-10 10z" />
                      </svg>
                      <span>Pin</span>
                    </button>
                  </div>

                  <AIPanel
                    content={data.content}
                    title={data.title}
                    writer={writer?.name || data.writer}
                  />

                  <div class="mt-12 bg-indigo-50/40 backdrop-blur-md rounded-[2.5rem] p-8 md:p-12 border border-indigo-100/30 relative">
                    <div
                      id="translation-loader"
                      class="absolute inset-0 bg-white/80 backdrop-blur-sm z-50 flex items-center justify-center rounded-[2.5rem] hidden"
                    >
                      <div class="flex items-center gap-3">
                        <div class="w-2 h-2 bg-primary rounded-full animate-bounce" />
                        <div class="w-2 h-2 bg-primary rounded-full animate-bounce delay-75" />
                        <div class="w-2 h-2 bg-primary rounded-full animate-bounce delay-150" />
                        <span class="text-xs font-bold uppercase tracking-widest text-primary/40">
                          Translating...
                        </span>
                      </div>
                    </div>
                    <h2 class="font-bold text-xs uppercase tracking-[0.3em] text-primary/40 mb-8 flex items-center space-x-3">
                      <BookOpen size={18} />
                      <span>Meaning & Context</span>
                    </h2>
                    <div
                      id="translated-content"
                      class="prose prose-indigo prose-lg text-primary/70 leading-relaxed space-y-6 max-w-none font-medium"
                    >
                      <p class="text-primary/80 italic">
                        "{data.content?.split("\n")[0]}..."
                      </p>
                      <p>
                        {data.meaning ||
                          `This powerful line by ${writer?.name || "the poet"} explores the delicate balance of emotion and expression. It serves as a testament to the enduring power of verse.`}
                      </p>
                    </div>
                  </div>
                </div>
              </article>

              {/* Tags / Categories */}
              <div class="bg-white/30 backdrop-blur-xl rounded-[2.5rem] p-8 md:p-10 border border-white/40">
                <h3 class="text-xs font-black text-primary/30 uppercase tracking-[0.2em] mb-6 flex items-center gap-3">
                  <Bookmark size={16} />
                  <span>Classified Tags</span>
                </h3>
                <div class="flex flex-wrap gap-3">
                  {data.category?.map((cat: string) => (
                    <a
                      href={`/${getCategorySlug(cat)}/`}
                      class="px-5 py-2 bg-white border border-indigo-100 rounded-full text-xs font-bold text-indigo-600 hover:bg-indigo-600 hover:text-white transition-all shadow-sm"
                    >
                      #{cat.toLowerCase()}
                    </a>
                  ))}
                  {writer && (
                    <a
                      href={`/${writer.slug}/`}
                      class="px-5 py-2 bg-indigo-50 border border-indigo-100 rounded-full text-xs font-bold text-indigo-600 hover:bg-indigo-600 hover:text-white transition-all shadow-sm"
                    >
                      #{writer.name?.toLowerCase().replace(/\s+/g, "")}
                    </a>
                  )}
                </div>
              </div>

              {/* Digital Poster */}
              {posterUrl && (
                <div class="bg-white/70 backdrop-blur-2xl rounded-[3rem] p-10 md:p-12 border border-white/40 shadow-xl overflow-hidden">
                  <div class="flex items-center justify-between mb-8">
                    <div>
                      <h3 class="text-2xl font-serif font-black text-primary mb-1">
                        Visual Poster
                      </h3>
                      <p class="text-primary/40 text-sm">
                        Download for social stories.
                      </p>
                    </div>
                    <a
                      href={posterUrl}
                      download
                      class="p-4 bg-indigo-600 text-white rounded-full hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-100"
                    >
                      <Download size={24} />
                    </a>
                  </div>
                  <div class="rounded-2xl overflow-hidden border border-indigo-50 shadow-inner">
                    <img
                      src={posterUrl}
                      alt={`${data.title} Poster`}
                      class="w-full object-contain"
                      loading="lazy"
                    />
                  </div>
                </div>
              )}
            </div>

            {/* Sidebar Column */}
            <aside class="lg:col-span-4 space-y-8">
              {/* Writer Profile Mini */}
              {writer && (
                <div class="bg-indigo-900 text-white rounded-[3rem] p-8 relative overflow-hidden group shadow-2xl">
                  <div class="absolute -top-12 -right-12 w-32 h-32 bg-white/10 blur-[60px] rounded-full" />
                  <div class="relative z-10">
                    <div class="flex items-center gap-5 mb-6">
                      <img
                        src={writer.photo}
                        class="w-20 h-20 rounded-2xl object-cover border-2 border-white/20"
                        alt={writer.name}
                      />
                      <div>
                        <h3 class="font-serif font-bold text-xl">
                          {writer.name}
                        </h3>
                        <p class="text-white/50 text-xs font-bold uppercase tracking-widest">
                          Poet & Author
                        </p>
                      </div>
                    </div>
                    <p class="text-white/70 text-sm leading-relaxed mb-6 line-clamp-3">
                      {writer.bio}
                    </p>
                    <a
                      href={`/${writer.slug}/`}
                      class="w-full py-4 bg-white/10 hover:bg-white/20 rounded-2xl text-center text-sm font-bold transition-all block border border-white/5"
                    >
                      View Full Profile
                    </a>
                  </div>
                </div>
              )}

              {/* Related Content Sidebar */}
              <div class="bg-white rounded-[3.5rem] p-8 border border-indigo-50 shadow-xl">
                <h3 class="text-lg font-serif font-black text-primary mb-6 flex items-center gap-3">
                  <Sparkles class="text-accent" size={20} />
                  <span>More Like This</span>
                </h3>
                <div class="space-y-6">
                  {poems.slice(0, 5).map((poem: any) => (
                    <a
                      href={
                        poem.id?.startsWith("ap-")
                          ? `/line/ap/${poem.writerSlug || currentWriterSlug}/${poem.slug}/`
                          : `/line/${poem.slug}/`
                      }
                      class="group block py-4 border-b border-indigo-50 last:border-0"
                    >
                      <p class="text-sm font-medium text-primary/80 line-clamp-2 group-hover:text-indigo-600 transition-colors mb-2 italic">
                        "
                        {poem.content ||
                          `Discover this poetic masterpiece by ${poem.writerName || poem.writer?.replace(/-/g, " ")}...`}
                        "
                      </p>
                      <div class="flex items-center justify-between text-[10px] font-black uppercase tracking-widest text-primary/30">
                        <span>Read More</span>
                        <ChevronRight size={12} />
                      </div>
                    </a>
                  ))}
                </div>
              </div>

              {/* Popular Categories Widget */}
              <div class="bg-indigo-50/50 rounded-[3.5rem] p-8 border border-white shadow-inner">
                <h3 class="text-xs font-black text-primary/40 uppercase tracking-[0.2em] mb-6">
                  Discovery
                </h3>
                <div class="flex flex-wrap gap-2">
                  {["Life", "Love", "Wisdom", "Nature", "Time"].map((cat) => (
                    <a
                      href={`/${slugify(cat)}/`}
                      class="px-4 py-2 bg-white rounded-full text-[10px] font-bold text-primary/60 hover:text-indigo-600 transition-colors border border-indigo-100/50"
                    >
                      {cat}
                    </a>
                  ))}
                </div>
              </div>
            </aside>
          </div>

          {/* Related Lines */}
          {poems.length > 0 && (
            <div class="mt-24">
              <h3 class="text-2xl font-serif font-black text-primary mb-10 flex items-center space-x-4">
                <Sparkles class="text-accent" size={24} />
                <span>Related Poetic Lines</span>
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {poems.map((poem: any) => (
                  <PoemCard
                    id={poem.id}
                    slug={
                      poem.id.startsWith("ap-")
                        ? `ap/${poem.writerSlug}/${poem.slug}`
                        : poem.slug
                    }
                    content={
                      poem.content ||
                      `A featured work from our extended library. Discover the timeless poetry and moving lines of ${poem.writerName || poem.writer?.replace(/-/g, " ")}.`
                    }
                    writer={
                      poem.id.startsWith("ap-")
                        ? `poet/${poem.writerSlug}`
                        : poem.writer
                    }
                    writerName={
                      poem.writerName || poem.writer?.replace(/-/g, " ")
                    }
                  />
                ))}
              </div>
            </div>
          )}

          {/* Writer Profile */}
          {writer && (
            <a
              href={`/${writer.slug}/`}
              class="mt-16 p-10 bg-white border border-indigo-50 rounded-[3rem] shadow-xl flex flex-col md:flex-row items-center space-y-8 md:space-y-0 md:space-x-10 hover:shadow-2xl transition-all duration-500 block"
            >
              <div class="w-32 h-32 md:w-40 md:h-40 flex-shrink-0 rounded-3xl overflow-hidden border-4 border-indigo-50">
                <img
                  src={writer.photo}
                  class="w-full h-full object-cover"
                  alt={writer.name}
                  loading="lazy"
                />
              </div>
              <div class="flex-grow text-center md:text-left">
                <h3 class="text-2xl font-serif font-black text-primary mb-3">
                  About {writer.name}
                </h3>
                <p class="text-primary/60 leading-relaxed mb-6">
                  {writer.bio?.slice(0, 180)}...
                </p>
                <span class="inline-flex items-center space-x-3 text-accent font-bold uppercase tracking-widest text-sm">
                  <span>Full Bibliography</span>
                  <ChevronRight size={18} />
                </span>
              </div>
            </a>
          )}

          {/* Sticky Read Next (Reduce Bounce Rate) */}
          <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-50 w-[90%] max-w-lg animate-in slide-in-from-bottom-20 duration-1000 delay-1000">
            <div
              class="bg-primary/90 backdrop-blur-2xl text-white p-6 rounded-[2rem] shadow-2xl border border-white/10 flex items-center justify-between group cursor-pointer"
              onclick={`window.location.href='/line/${poems[0]?.slug || ""}/'`}
            >
              <div class="flex items-center space-x-4 overflow-hidden">
                <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center grow-0 shrink-0">
                  <Sparkles size={20} class="text-accent" />
                </div>
                <div class="overflow-hidden">
                  <span class="block text-[10px] font-black uppercase tracking-[0.2em] text-white/40 mb-1">
                    Continure Reading
                  </span>
                  <p class="text-sm font-bold truncate pr-4 italic">
                    "{poems[0]?.content?.slice(0, 50)}..."
                  </p>
                </div>
              </div>
              <div class="p-3 bg-accent rounded-xl text-white group-hover:scale-110 transition-transform">
                <ChevronRight size={20} />
              </div>
            </div>
          </div>
        </div>
      )
    }

    {
      /* ========== WRITER / CATEGORY / COLLECTION PAGES (unchanged functionally, but improved spacing) ========== */
    }
    {
      type !== "line" && (
        <div class={type === "writer" ? "pt-24 pb-40" : "py-24"}>
          <div class="container mx-auto px-4 text-center max-w-4xl">
            <Breadcrumb items={breadcrumbs} />
            {type === "writer" && (
              <img
                src={data.photo}
                class="w-40 h-40 md:w-56 md:h-56 rounded-[3rem] object-cover shadow-2xl border-4 border-white mb-8 mt-6 mx-auto"
                alt={data.name}
                loading="lazy"
              />
            )}
            <h1 class="text-4xl md:text-7xl font-serif font-black text-primary mb-6 mt-4">
              {data.name}
            </h1>
            <p class="text-lg md:text-xl text-primary/60 leading-relaxed max-w-3xl mx-auto">
              {data.bio || data.seoIntro || data.description}
            </p>
            <div class="mt-8 text-sm text-primary/40 font-bold uppercase tracking-widest">
              {poems.length} Lines Found
            </div>
          </div>

          <div class="container mx-auto px-4 mt-20">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 pb-24">
              {poems.map((poem: any) => (
                <PoemCard
                  id={poem.id}
                  slug={
                    poem.id.startsWith("ap-")
                      ? `ap/${poem.writerSlug || currentWriterSlug}/${poem.slug}`
                      : poem.slug
                  }
                  content={
                    poem.content ||
                    `Discover the soul-stirring poetry and profound lines of ${type === "writer" ? data.name : poem.writerName || poem.writer}. A featured work from our extended library.`
                  }
                  writer={
                    poem.id.startsWith("ap-")
                      ? `poet/${poem.writerSlug || data.slug}`
                      : poem.writer
                  }
                  writerName={
                    type === "writer"
                      ? data.name
                      : poem.writerName || poem.writer?.replace(/-/g, " ")
                  }
                />
              ))}
            </div>
          </div>
        </div>
      )
    }
  </main>

  <Footer />
</Layout>

<script>
  const copyBtn = document.getElementById("copy-btn");
  const whatsappBtn = document.getElementById("whatsapp-btn");
  const pinBtn = document.getElementById("pin-btn");

  const poemContent = document.querySelector("blockquote p")?.textContent || "";
  const currentUrl = window.location.href;
  const posterImg = document.querySelector('img[alt$="Poster"]');
  const imageUrl = posterImg
    ? `${window.location.origin}${posterImg.getAttribute("src") || ""}`
    : "";

  function doCopy(btn: any) {
    navigator.clipboard.writeText(poemContent).then(() => {
      const span = btn?.querySelector("span");
      if (span) {
        const old = span.textContent;
        span.textContent = "Copied!";
        setTimeout(() => {
          span.textContent = old;
        }, 2000);
      }
    });
  }

  function doWhatsApp() {
    const waUrl = `https://api.whatsapp.com/send?text=${encodeURIComponent(poemContent.slice(0, 100))}... Read more at: ${currentUrl}`;
    window.open(waUrl, "_blank");
  }

  function doPin() {
    const pinUrl = `https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(currentUrl)}&media=${encodeURIComponent(imageUrl)}&description=${encodeURIComponent(poemContent.slice(0, 200))}`;
    window.open(pinUrl, "_blank");
  }

  copyBtn?.addEventListener("click", () => doCopy(copyBtn));
  whatsappBtn?.addEventListener("click", doWhatsApp);
  pinBtn?.addEventListener("click", doPin);

  // Auto-translation logic
  async function triggerAutoTranslation() {
    const langCode = document
      .querySelector('meta[name="lang-trigger"]')
      ?.getAttribute("content");
    if (!langCode || langCode === "en") return;

    const loader = document.getElementById("translation-loader");
    const contentContainer = document.getElementById("translated-content");
    const mainQuote = document.querySelector("blockquote p");

    if (!loader || !contentContainer || !mainQuote) return;

    loader.classList.remove("hidden");

    try {
      const { translateContent } = await import("../lib/translate");

      // Translate the main poem content
      const translatedPoem = await translateContent(
        mainQuote.textContent,
        langCode,
      );
      if (translatedPoem) mainQuote.textContent = translatedPoem;

      // Translate the meaning/context
      const paragraphs = contentContainer.querySelectorAll("p");
      for (const p of paragraphs) {
        const translated = await translateContent(p.textContent, langCode);
        if (translated) p.textContent = translated;
      }

      // Update Page Title
      const translatedTitle = await translateContent(
        document.title.split("|")[0],
        langCode,
      );
      if (translatedTitle) document.title = `${translatedTitle} | Linespedia`;
    } catch (e) {
      console.error("Translation Auto-Trigger Error:", e);
    } finally {
      loader.classList.add("hidden");
    }
  }

  if (window.location.search.includes("lang=")) {
    triggerAutoTranslation();
  }
</script>

