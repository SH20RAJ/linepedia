---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PoemCard from '../components/PoemCard.astro';
import { Share2, Copy, Heart, BookOpen, Quote, ChevronRight, Bookmark } from 'lucide-astro';

export async function getStaticPaths() {
	const poemsData = (await import('../content/poems.json')).default;
	const writersData = (await import('../content/writers.json')).default;
	const categoriesData = (await import('../content/categories.json')).default;
	const collectionsData = (await import('../content/collections.json')).default;

	const paths = [];

	// 1. Individual Line Pages
	poemsData.forEach(poem => {
		const writer = writersData.find(w => w.slug === poem.writer);
		paths.push({
			params: { slug: `line/${poem.slug}` },
			props: { type: 'line', data: poem, writer }
		});
	});

	// 2. Writer Pages
	writersData.forEach(writer => {
		const writerPoems = poemsData.filter(p => p.writer === writer.slug);
		paths.push({
			params: { slug: writer.slug },
			props: { type: 'writer', data: writer, poems: writerPoems }
		});
	});

	// 3. Category Pages
	categoriesData.forEach(cat => {
		const catPoems = poemsData.filter(p => p.category.includes(cat.slug));
		paths.push({
			params: { slug: cat.slug },
			props: { type: 'category', data: cat, poems: catPoems }
		});
	});

	// 4. Collection Pages
	collectionsData.forEach(col => {
		let colPoems = poemsData;
		if (col.filter.category) {
			colPoems = colPoems.filter(p => p.category.includes(col.filter.category));
		}
		if (col.filter.mood) {
			colPoems = colPoems.filter(p => p.mood.includes(col.filter.mood));
		}
		paths.push({
			params: { slug: col.slug },
			props: { type: 'collection', data: col, poems: colPoems }
		});
	});

	return paths;
}

const { type, data, writer, poems } = Astro.props;
const writersData = (await import('../content/writers.json')).default;
---

<Layout 
	title={type === 'line' ? data.title : data.name} 
	description={type === 'line' ? data.content.slice(0, 160) : data.description || data.seoIntro || data.bio}
>
	<Navbar />

	<main class="min-h-screen bg-cream">
		{type === 'line' && (
			<div class="container mx-auto px-4 py-12 md:py-24 grid grid-cols-1 lg:grid-cols-12 gap-12">
				<!-- Main Content Area -->
				<div class="lg:col-span-8 flex flex-col items-center">
					<div class="w-full max-w-2xl bg-white border border-indigo-50 rounded-[3rem] p-12 md:p-20 shadow-2xl relative overflow-hidden">
						<div class="absolute top-0 right-0 p-8 opacity-5 text-primary">
							<Quote size={80} />
						</div>
						
						<div class="relative z-10 flex flex-col items-center text-center">
							<div class="text-accent mb-8">
								<Heart size={40} fill="currentColor" />
							</div>
							
							<blockquote class="text-3xl md:text-5xl font-serif font-black text-primary leading-tight md:leading-snug mb-12">
								<p class="whitespace-pre-line prose prose-indigo">
									{data.content}
								</p>
							</blockquote>

							<div class="flex flex-wrap justify-center gap-4 mb-12">
								<button class="bg-primary text-white px-8 py-4 rounded-full font-bold flex items-center space-x-2 hover:bg-primary/90 transition-all shadow-xl hover:shadow-primary/20">
									<Copy size={20} />
									<span>Copy Line</span>
								</button>
								<button class="bg-white border-2 border-primary text-primary px-8 py-4 rounded-full font-bold flex items-center space-x-2 hover:bg-indigo-50 transition-all">
									<Share2 size={20} />
									<span>Share</span>
								</button>
							</div>

							<!-- Meaning Section -->
							<div class="w-full text-left bg-indigo-50/50 rounded-3xl p-8 border border-indigo-100/50">
								<h3 class="font-bold text-xs uppercase tracking-widest text-primary/40 mb-4 flex items-center space-x-2">
									<BookOpen size={16} />
									<span>Meaning & Context</span>
								</h3>
								<p class="text-primary/70 leading-relaxed italic">
									"{data.meaning}"
								</p>
							</div>
						</div>
					</div>

					<!-- Writer Mini Card -->
					<div class="mt-12 w-full max-w-2xl flex items-center p-6 bg-white border border-indigo-100 rounded-3xl shadow-sm hover:shadow-md transition-all group">
						<img src={writer.photo} class="w-16 h-16 rounded-2xl object-cover mr-6 border-2 border-indigo-100" />
						<div class="flex-grow">
							<h4 class="text-lg font-bold text-primary group-hover:text-accent transition-colors">By {writer.name}</h4>
							<p class="text-sm text-primary/50">{writer.bio.slice(0, 60)}...</p>
						</div>
						<a href={`/${writer.slug}`} class="p-4 rounded-2xl bg-indigo-50 text-primary hover:bg-primary hover:text-white transition-all">
							<ChevronRight size={24} />
						</a>
					</div>
				</div>

				<!-- Sticky Floating Panel (Desktop) -->
				<aside class="hidden lg:block lg:col-span-4 h-full">
					<div class="sticky top-28 space-y-8">
						<div class="bg-white border border-indigo-50 rounded-3xl p-8 shadow-sm">
							<h3 class="font-bold text-xs uppercase tracking-widest text-primary/40 mb-6">Explore Tags</h3>
							<div class="flex flex-wrap gap-2">
								{data.category.map(tag => (
									<a href={`/${tag}`} class="px-4 py-2 bg-indigo-50 rounded-xl text-primary font-medium hover:bg-accent hover:text-white transition-all">
										#{tag}
									</a>
								))}
							</div>
						</div>
					</div>
				</aside>
			</div>
		)}

		{type === 'writer' && (
			<div>
				<div class="poetic-gradient pt-24 pb-40">
					<div class="container mx-auto px-4 flex flex-col items-center">
						<img src={data.photo} class="w-40 h-40 md:w-56 md:h-56 rounded-[3rem] object-cover shadow-2xl border-4 border-white mb-8" />
						<h1 class="text-5xl md:text-7xl font-serif font-black text-primary mb-4">{data.name}</h1>
						<p class="text-xl text-primary/60 max-w-2xl text-center leading-relaxed">{data.bio}</p>
					</div>
				</div>
				<div class="container mx-auto px-4 -mt-20">
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 pb-24">
						{poems.map(poem => (
							<PoemCard 
								id={poem.id}
								slug={poem.slug}
								content={poem.content}
								writer={poem.writer}
								writerName={data.name}
							/>
						))}
					</div>
				</div>
			</div>
		)}

		{(type === 'category' || type === 'collection') && (
			<div>
				<div class="poetic-gradient py-24 border-b border-indigo-50">
					<div class="container mx-auto px-4 max-w-4xl">
						<h1 class="text-5xl md:text-7xl font-serif font-black text-primary mb-6">{data.name}</h1>
						<p class="text-xl text-primary/60 leading-relaxed font-medium">{data.seoIntro || data.description}</p>
					</div>
				</div>
				<div class="container mx-auto px-4 py-16">
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 pb-24">
						{poems.map(poem => (
							<PoemCard 
								id={poem.id}
								slug={poem.slug}
								content={poem.content}
								writer={poem.writer}
								writerName={writersData.find(w => w.slug === poem.writer)?.name || poem.writer}
							/>
						))}
					</div>
				</div>
			</div>
		)}
	</main>

	<Footer />
</Layout>
