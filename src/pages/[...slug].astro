---
import Layout from '../layouts/Layout.astro';
import writersData from '../content/writers.json';
import { getEntry } from "astro:content";

export const prerender = false;

const { slug } = Astro.params;
let data = null;
let error = null;

try {
    if (slug?.startsWith('line/')) {
        const entry = await getEntry('poems', slug.replace('line/', ''));
        if (entry) {
            data = entry.data;
        } else {
            // Check KV fallback
            const kv = (Astro.locals as any).runtime?.env?.SESSION;
            if (kv) {
                const kvData = await kv.get(slug.replace('line/', ''));
                if (kvData) data = JSON.parse(kvData);
            }
        }
    }
} catch (e: any) {
    error = e.message;
}

if (!data && !error) return Astro.redirect('/404');
---

<Layout title={data?.title || "Poetry"}>
    <main class="p-20">
        {error && <div class="p-4 bg-red-100 text-red-700">Error: {error}</div>}
        {data && (
            <article>
                <h1 class="text-4xl font-black mb-8">{data.title}</h1>
                <pre class="whitespace-pre-wrap text-xl">{data.content}</pre>
            </article>
        )}
        {!data && !error && <p>No data found.</p>}
    </main>
</Layout>
