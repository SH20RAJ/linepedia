---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PoemCard from '../../components/PoemCard.astro';
import StructuredData from '../../components/StructuredData.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AIPanel from '../../components/AIPanel.astro';
import { Share2, Copy, Heart, BookOpen, Quote, ChevronRight, Bookmark, Download, Sparkles } from 'lucide-astro';

import { 
    getPoem, 
    getAllWriters, 
    getPoemIdBySlug,
    getRelatedPoems,
    getPosterUrl 
} from '../../lib/cdn';

export const prerender = true;

export async function getStaticPaths() {
    const CDN_BASE = 'https://cdn.jsdelivr.net/gh/BluredCodes/linespedia-data@main';
    const res = await fetch(`${CDN_BASE}/metadata/v1/slug-map.json`);
    const slugMap = await res.json() as Record<string, string>;

    return Object.keys(slugMap).map(slug => ({
        params: { slug }
    }));
}

const { slug } = Astro.params;

async function getPageData() {
    if (!slug) return null;
    
    const writers = await getAllWriters();
    const id = await getPoemIdBySlug(slug);
    
    if (id) {
        const data = await getPoem(id);
        if (data) {
            const writerSlug = typeof data.writer === 'string' ? data.writer.toLowerCase().trim().replace(/\s+/g, '-').replace(/[^\w-]+/g, '').replace(/--+/g, '-') : '';
            const writer = writers.find((w: any) => w.slug === writerSlug);
            const related = await getRelatedPoems(writerSlug, data.category || []);
            const relatedPoems = related.filter((p: any) => p.slug !== slug);
            
            return { data, writer, relatedPoems };
        }
    }
    return null;
}

const pageData = await getPageData();

if (!pageData) return Astro.redirect('/404');

const { data, writer, relatedPoems } = pageData;

const title = `${data.title} — Poetry Lines | Linespedia`;
const description = `${data.content?.slice(0, 140)}... Read meaning and context.`;

const breadcrumbs = [
    { name: 'Poetry', href: '/explore/' },
    { name: writer?.name || 'Poet', href: writer ? `/${writer.slug}/` : '#' },
    { name: data.title, href: `/p/${slug}/` }
];

const posterUrl = getPosterUrl(data.slug);
---

<Layout title={title} description={description} type="article">
    <StructuredData
        type="line"
        title={title}
        description={description}
        url={Astro.url.pathname}
        authorName={writer?.name || data.writer}
        datePublished={data.createdAt}
        breadcrumbs={breadcrumbs.map((b: any) => ({ name: b.name, url: b.href }))}
    />

    <Navbar />
    
    <main class="min-h-screen poetic-gradient">
        <div class="container mx-auto px-4 py-12 md:py-32 max-w-5xl animate-in fade-in slide-in-from-bottom-8 duration-1000">
            <Breadcrumb items={breadcrumbs} />
            
            <article class="mt-8 bg-white/70 backdrop-blur-2xl border border-white/40 rounded-[4rem] p-10 md:p-20 shadow-2xl relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-12 opacity-[0.03] text-primary group-hover:scale-110 transition-transform duration-700">
                    <Quote size={120} />
                </div>
                
                <div class="relative z-10 flex flex-col items-center text-center">
                    <h1 class="text-xs font-bold uppercase tracking-[0.4em] text-primary/30 mb-8 md:mb-12 text-center">Poetic Insight</h1>
                    
                    <blockquote class="text-3xl md:text-6xl font-serif font-black text-primary leading-tight md:leading-snug mb-16 selection:bg-accent/20 italic max-w-4xl mx-auto text-center">
                        <p class="whitespace-pre-line drop-shadow-sm">{data.content}</p>
                    </blockquote>

                    <div class="flex flex-wrap justify-center gap-6 mb-16">
                        <button id="copy-btn" class="bg-primary text-white px-10 py-5 rounded-full font-bold flex items-center space-x-3 hover:bg-primary/90 hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-primary/20">
                            <Copy size={20} />
                            <span>Copy Line</span>
                        </button>
                        <button id="pin-btn" class="bg-[#E60023] text-white px-10 py-5 rounded-full font-bold flex items-center space-x-3 hover:bg-[#ad001a] hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-red-500/20">
                            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-1.14 0-2.22-.23-3.21-.64.45-.89 1.11-2.47 1.37-3.57.14-.58.72-2.97.72-2.97.38.72 1.48 1.33 2.65 1.33 3.49 0 6.03-3.2 6.03-7.18 0-3.81-3.11-6.67-7.18-6.67C8.09 2.3 4 5.7 4 10.12c0 2.42 1.27 4.32 3.29 5.08.17.07.33 0 .38-.18.04-.14.13-.49.17-.64.06-.21.04-.28-.12-.46-.35-.4-.64-1.13-.64-1.82 0-2.63 1.97-5.17 5.32-5.17 2.9 0 4.94 1.97 4.94 4.78 0 3.19-1.61 5.41-3.71 5.41-1.16 0-2.02-.96-1.74-2.13.33-1.4 .97-2.91.97-3.92 0-.9-.48-1.65-1.49-1.65-1.18 0-2.13 1.22-2.13 2.86 0 1.04.35 1.75.35 1.75s-1.2 5.11-1.41 5.96c-.21.86-.12 2.08-.04 2.87A9.96 9.96 0 012 12c0-5.52 4.48-10 10-10s10 4.48 10 10-4.48 10-10 10z"/></svg>
                            <span>Pin</span>
                        </button>
                    </div>

                    <AIPanel content={data.content} title={data.title} writer={writer?.name || data.writer} />

                    <div class="w-full text-left bg-indigo-50/40 backdrop-blur-md rounded-[2.5rem] p-10 md:p-14 border border-indigo-100/30 mt-12">
                        <h2 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
                            <BookOpen size={20} class="text-indigo-600" />
                            Poem Meaning & Analysis
                        </h2>
                        <p class="text-slate-700 leading-relaxed text-lg font-medium italic">
                            {data.meaning || `This powerful line by ${writer?.name || data.writer} explores the delicate balance of emotion and expression.`}
                        </p>
                    </div>

                    {posterUrl && (
                        <div class="mt-20 w-full pt-16 border-t border-indigo-50/50 text-left">
                            <div class="flex items-end justify-between mb-12">
                                <div>
                                    <h3 class="text-3xl font-serif font-black text-primary mb-2 text-left">Visual Discovery</h3>
                                    <p class="text-primary/40">Download or share as a digital poster.</p>
                                </div>
                                <a href={posterUrl} download class="hidden md:flex items-center space-x-3 px-8 py-4 bg-white border-2 border-primary/10 rounded-full text-sm font-bold text-primary hover:bg-primary hover:text-white transition-all">
                                    <Download size={20} />
                                    <span>Download</span>
                                </a>
                            </div>
                            <div class="rounded-3xl border border-indigo-50/50 overflow-hidden shadow-2xl max-w-lg mx-auto md:mx-0">
                                <img src={posterUrl} alt={`${data.title} Poster`} class="w-full" loading="lazy" />
                            </div>
                        </div>
                    )}
                </div>
            </article>

            {relatedPoems.length > 0 && (
                <div class="mt-24">
                    <h3 class="text-2xl font-serif font-black text-primary mb-10 flex items-center space-x-4">
                        <Sparkles class="text-accent" size={24} />
                        <span>Related Poetic Lines</span>
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        {relatedPoems.map((p: any) => (
                            <PoemCard id={p.id} slug={p.slug} content={p.content} writer={p.writer} writerName={p.writer?.replace(/-/g, ' ')} />
                        ))}
                    </div>
                </div>
            )}
        </div>
    </main>
    
    <Footer />
</Layout>

<script>
    const copyBtn = document.getElementById('copy-btn');
    const pinBtn = document.getElementById('pin-btn');

    const poemContent = document.querySelector('blockquote p')?.textContent || '';
    const currentUrl = window.location.href;
    const posterImg = document.querySelector('img[alt$="Poster"]');
    const imageUrl = posterImg ? `${window.location.origin}${posterImg.getAttribute('src') || ''}` : '';

    function doCopy(btn: any) {
        navigator.clipboard.writeText(poemContent).then(() => {
            const span = btn?.querySelector('span');
            if (span) {
                const old = span.textContent;
                span.textContent = 'Copied!';
                setTimeout(() => { span.textContent = old; }, 2000);
            }
        });
    }

    function doPin() {
        const pinUrl = `https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(currentUrl)}&media=${encodeURIComponent(imageUrl)}&description=${encodeURIComponent(poemContent.slice(0, 200))}`;
        window.open(pinUrl, '_blank');
    }

    copyBtn?.addEventListener('click', () => doCopy(copyBtn));
    pinBtn?.addEventListener('click', doPin);
</script>

<style>
    .poetic-gradient {
        background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.05), transparent 40%),
                    radial-gradient(circle at bottom left, rgba(236, 72, 153, 0.05), transparent 40%),
                    #fdfcf7;
    }
</style>
